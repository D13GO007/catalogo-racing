---
import '../../styles.css';
import { supabase } from '../../lib/supabase.js';

const { data: referencias, error } = await supabase
  .from('referencias')
  .select(`
    id,
    modelo,
    imagen_especifica,
    visible_en_catalogo
  `)
  .order('modelo');

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Catálogo - Tiendana</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="apple-touch-icon" href="/icono-192.png" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
      body {
        font-family: 'Inter', sans-serif;
        background: #e6e7ee;
        min-height: 100vh;
        color: #2d3748;
      }
      .neumorphism {
        background: #e6e7ee;
        box-shadow: 20px 20px 40px #bebebe, -20px -20px 40px #ffffff;
        border-radius: 20px;
      }
      .neumorphism-card {
        background: #e6e7ee;
        box-shadow: 10px 10px 20px #bebebe, -10px -10px 20px #ffffff;
        border-radius: 20px;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.6);
      }
      .neumorphism-card:hover {
        box-shadow: 16px 16px 32px rgba(0, 0, 0, 0.12), -16px -16px 32px rgba(255, 255, 255, 0.7);
        transform: translateY(-4px);
      }
      .search-input {
        width: 100%;
        max-width: 900px;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.85);
        box-shadow: 8px 8px 18px rgba(0, 0, 0, 0.06), -8px -8px 18px rgba(255, 255, 255, 0.8);
        outline: none;
        transition: all 0.2s ease;
      }
      .search-input:focus {
        border-color: rgba(255, 107, 53, 0.6);
        box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.15);
      }
      .toggle {
        position: relative;
        width: 58px;
        height: 28px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.12);
        cursor: pointer;
        transition: background 0.25s ease;
      }
      .toggle::after {
        content: '';
        position: absolute;
        top: 3px;
        left: 3px;
        width: 22px;
        height: 22px;
        border-radius: 999px;
        background: white;
        box-shadow: 2px 2px 6px rgba(0, 0, 0, 0.15);
        transition: transform 0.25s ease, background 0.25s ease;
      }
      .toggle.active {
        background: rgba(34, 197, 94, 0.35);
        border-color: rgba(34, 197, 94, 0.55);
      }
      .toggle.active::after {
        transform: translateX(30px);
        background: rgba(34, 197, 94, 0.95);
      }
      .card-img {
        width: 100%;
        height: 200px;
        border-radius: 16px;
        object-fit: contain;
        background: radial-gradient(circle at top, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.5));
      }
    </style>
  </head>
  <body>
    <header class="w-full h-16 bg-gray-900 shadow-lg border-b-4 border-orange-500 relative z-10 flex items-center shrink-0">
      <div class="w-full max-w-[98%] mx-auto px-4 flex justify-between items-center">
        
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg overflow-hidden shrink-0 border border-gray-700">
            <img src="/logo.png" alt="Premium Racing" class="w-full h-full object-contain p-1" onerror="this.src='https://placehold.co/100x100?text=PR'" />
          </div>
          <div class="hidden lg:block">
            <h1 class="text-xl font-bold text-white tracking-wide leading-tight">Premium Racing</h1>
            <p class="text-orange-400 text-[10px] font-black uppercase tracking-widest">Sistema de Gestión</p>
          </div>
        </div>

        <nav class="flex gap-1 md:gap-2 overflow-x-auto custom-scrollbar pb-1 md:pb-0">
          <a href="/pos/inicio" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="hidden md:inline">Inicio</span>
          </a>
          <a href="/pos/ventas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span class="hidden md:inline">Ventas</span>
          </a>

          <a href="/pos/historial" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="hidden md:inline">Historial</span>
          </a>
          <a href="/pos" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="hidden md:inline">Inventario</span>
          </a>

          <a href="/pos/estadisticas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            <span class="hidden md:inline">Estadísticas</span>
          </a>
        </nav>
        
        <div class="hidden sm:block ml-2 pl-2 md:ml-4 md:pl-4 border-l border-gray-700 shrink-0">
           <button class="text-gray-400 hover:text-red-400 transition-colors p-2 rounded-lg hover:bg-gray-800" title="Cerrar Sesión">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
               <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
             </svg>
           </button>
        </div>

      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8">
      <div class="neumorphism px-6 py-5 mb-6">
        <input id="search" class="search-input" type="search" placeholder="Buscar modelo..." />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="cardGrid">
        {referencias?.length ? (
          referencias.map((ref) => (
            <div class="neumorphism-card p-5" data-model={ref.modelo.toLowerCase()} data-id={ref.id}>
              <img
                src={ref.imagen_especifica || 'https://placehold.co/400x400?text=Sin+imagen'}
                alt={ref.modelo}
                class="card-img mb-4"
              />
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm text-gray-500">Modelo</p>
                  <p class="font-semibold text-lg text-gray-900">{ref.modelo}</p>
                </div>
                <button class={`toggle ${ref.visible_en_catalogo ? 'active' : ''}`} data-id={ref.id} aria-label="Toggle visibilidad"></button>
              </div>
            </div>
          ))
        ) : (
          <div class="col-span-full rounded-lg border border-dashed border-gray-300 bg-white/60 p-8 text-center text-gray-600">
            No se encontraron productos.
          </div>
        )}
      </div>
    </main>

    <script type="module">
      import { supabase } from '../../lib/supabase.js';

      const search = document.getElementById('search');
      const cards = Array.from(document.querySelectorAll('[data-model]'));

      const applySearch = () => {
        const q = search.value.trim().toLowerCase();
        cards.forEach(card => {
          const model = card.getAttribute('data-model');
          card.style.display = model.includes(q) ? 'block' : 'none';
        });
      };

      search.addEventListener('input', applySearch);

      const setToggle = async (button, visible) => {
        const id = button.getAttribute('data-id');
        button.classList.toggle('active', visible);

        const { error } = await supabase
          .from('referencias')
          .update({ visible_en_catalogo: visible })
          .eq('id', id);

        if (error) {
          console.error('Error actualizando visibilidad', error);
          button.classList.toggle('active', !visible);
        }
      };

      document.querySelectorAll('.toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const isActive = btn.classList.contains('active');
          setToggle(btn, !isActive);
        });
      });
    </script>
    <script>
      (function() {
        const currentPath = window.location.pathname.replace(/\/$/, ""); 
        const navLinks = document.querySelectorAll('.nav-link');
        
        navLinks.forEach(link => {
          const href = link.getAttribute('href')?.replace(/\/$/, ""); 
          const isMatch = (href === '/pos') ? (currentPath === '/pos') : (href && currentPath.includes(href));

          if (isMatch) {
            link.classList.remove('text-gray-300', 'border-transparent', 'hover:bg-gray-800', 'hover:text-white');
            link.classList.add('bg-gray-800', 'text-orange-400', 'border-gray-700', 'shadow-inner');
          }
        });
      })();
    </script>
  </body>
</html>
