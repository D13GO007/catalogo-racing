    <div id="modalAbono" class="hidden fixed inset-0 bg-neutral-950/80 z-[300] backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-200">
      <div class="neumorphism w-full max-w-sm p-6 bg-[#e6e7ee] rounded-[2rem] border border-white/50 scale-95 transition-transform duration-200" id="modalAbonoBox">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-xl font-black text-gray-800">Registrar Pago</h3>
          <button id="closeAbono" class="text-gray-400 hover:text-red-500"><svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg></button>
        </div>
        <div class="space-y-4">
          <div class="bg-orange-50 p-3 rounded-xl border border-orange-200">
            <p class="text-xs font-bold text-orange-600 uppercase mb-1">Saldo Pendiente Actual</p>
            <p class="text-2xl font-black text-orange-700" id="abonoSaldoFaltante">$0</p>
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Monto a Ingresar</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 font-bold">$</span>
              <input type="text" id="inputMontoAbono" class="w-full bg-white border border-gray-300 text-gray-900 font-bold text-lg rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 block pl-8 p-3 shadow-sm" placeholder="0">
            </div>
