    <script is:inline define:vars={{ ordenes }}>
      window.ORDENES_DB = ordenes;
    </script>

    <script>
      import { supabase } from '../../lib/supabase.js';
      import { generarFacturaPDF } from '../../pos/ventas/pdf.js';

      const formatoPesos = (num: number) => '$' + Math.round(num).toLocaleString('es-CO');
      const mostrarToast = (mensaje: string) => { alert(mensaje); };

      // ==========================================
      // LÓGICA DE PESTAÑAS
      // ==========================================
      const tabOrdenes = document.getElementById('tabOrdenes');
      const tabCartera = document.getElementById('tabCartera');
      const vistaOrdenes = document.getElementById('vistaOrdenes');
      const vistaCartera = document.getElementById('vistaCartera');

      const activarTab = (modo: string) => {
        if (modo === 'ordenes') {
          vistaCartera?.classList.add('hidden'); vistaOrdenes?.classList.remove('hidden');
          tabOrdenes?.classList.replace('text-gray-500', 'text-orange-600'); tabOrdenes?.classList.replace('border-transparent', 'border-orange-500');
          tabCartera?.classList.replace('text-orange-600', 'text-gray-500'); tabCartera?.classList.replace('border-orange-500', 'border-transparent');
        } else {
          vistaOrdenes?.classList.add('hidden'); vistaCartera?.classList.remove('hidden');
          tabCartera?.classList.replace('text-gray-500', 'text-orange-600'); tabCartera?.classList.replace('border-transparent', 'border-orange-500');
          tabOrdenes?.classList.replace('text-orange-600', 'text-gray-500'); tabOrdenes?.classList.replace('border-orange-500', 'border-transparent');
        }
      };
      tabOrdenes?.addEventListener('click', () => activarTab('ordenes'));
      tabCartera?.addEventListener('click', () => activarTab('cartera'));

      // ==========================================
      // LÓGICA DE CARTERA Y FILTROS
      // ==========================================
      const filtroDesde = document.getElementById('filtroDesde') as HTMLInputElement;
      const filtroHasta = document.getElementById('filtroHasta') as HTMLInputElement;
      const selectCliente = document.getElementById('selectCarteraCliente') as HTMLSelectElement;
      const inputRepuesto = document.getElementById('filtroRepuesto') as HTMLInputElement;
      const inputPMin = document.getElementById('filtroPrecioMin') as HTMLInputElement;
      const inputPMax = document.getElementById('filtroPrecioMax') as HTMLInputElement;
      const inputBuscarCartera = document.getElementById('inputBuscarCartera') as HTMLInputElement;
      const tbodyCartera = document.getElementById('tablaCarteraItems');

      const aplicarFiltroBuscadorCartera = () => {
        const termino = (inputBuscarCartera?.value || '').toLowerCase().trim();
        const filasCartera = document.querySelectorAll('.fila-cartera');

        filasCartera.forEach((fila) => {
          const filaEl = fila as HTMLElement;
          const nombreCliente = fila.children[1]?.textContent?.toLowerCase() || '';
          filaEl.style.display = nombreCliente.includes(termino) ? '' : 'none';
        });
      };

      const clientesMap = new Map();
      if (window.ORDENES_DB) {
        window.ORDENES_DB.forEach((o: any) => {
          if(o.cliente_nombre) {
            const nombre = o.cliente_nombre.toUpperCase();
            if(!clientesMap.has(nombre)) clientesMap.set(nombre, { nombre, tel: o.cliente_telefono });
          }
        });
        Array.from(clientesMap.values()).sort((a,b) => a.nombre.localeCompare(b.nombre)).forEach(c => {
            const opt = document.createElement('option'); opt.value = c.nombre;
            opt.textContent = `${c.nombre} ${c.tel && c.tel !== 'N/A' ? ' - ' + c.tel : ''}`;
            selectCliente?.appendChild(opt);
        });
      }

      const renderizarCartera = () => {
        const clienteSel = selectCliente?.value;
        if(!clienteSel) {
          document.getElementById('statsCartera')?.classList.add('hidden');
          if (tbodyCartera) tbodyCartera.innerHTML = '<tr><td colspan="6" class="text-center py-8 text-gray-400 font-bold">Selecciona un cliente para analizar.</td></tr>';
          return;
        }
        document.getElementById('statsCartera')?.classList.remove('hidden');

        const txtRepuesto = inputRepuesto?.value.toLowerCase() || '';
        const minP = parseFloat(inputPMin?.value) || 0;
        const maxP = parseFloat(inputPMax?.value) || Infinity;
        const d = filtroDesde?.value ? new Date(filtroDesde.value + 'T00:00:00').getTime() : 0;
        const h = filtroHasta?.value ? new Date(filtroHasta.value + 'T23:59:59').getTime() : Infinity;

        let totalGasto = 0; let totalDeuda = 0; let cantCompras = 0;
        const filasHTML: string[] = [];

        window.ORDENES_DB.filter((o: any) => o.cliente_nombre.toUpperCase() === clienteSel).forEach((orden: any) => {
          const t = new Date(orden.fecha).getTime();
          let items = []; try { items = typeof orden.items === 'string' ? JSON.parse(orden.items) : (orden.items || []); } catch(e){}

          if (t >= d && t <= h) {
            let pasaFiltroAvanzado = true;
            if (txtRepuesto !== '' || minP > 0 || maxP < Infinity) {
              pasaFiltroAvanzado = items.some((item: any) => {
                const desc = (item.modelo || item.descripcion || '').toLowerCase();
                const precio = item.precio_venta || item.precio || 0;
                return desc.includes(txtRepuesto) && precio >= minP && precio <= maxP;
              });
            }

            if (pasaFiltroAvanzado) {
              if(orden.estado === 'completada') totalGasto += orden.total_neto;
              if(orden.estado === 'pendiente' || orden.tipo_venta === 'credito') {
                 totalDeuda += (orden.total_neto - (orden.monto_recibido || 0));
              }
              cantCompras++;

              let badgeClass = "bg-gray-100 text-gray-700"; let estadoTexto = orden.estado.toUpperCase();
              if (orden.estado === 'completada') badgeClass = "bg-green-100 text-green-700 border-green-200";
              else if (orden.estado === 'cotizacion') badgeClass = "bg-blue-100 text-blue-700 border-blue-200";
              else if (orden.estado === 'pendiente' || orden.tipo_venta === 'credito') {
                badgeClass = "bg-orange-100 text-orange-700 border-orange-200"; estadoTexto = 'CRÉDITO';
              }

              const idCorto = orden.id ? orden.id.split('-').pop().substring(6).toUpperCase() : 'N/A';
              const fechaStr = new Date(orden.fecha).toLocaleDateString('es-CO') + ' ' + new Date(orden.fecha).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true });

              filasHTML.push(`
                <tr class="orden-row-cartera fila-cartera hover:bg-orange-50/50 transition-colors cursor-pointer border-b border-gray-100" data-id="${orden.id}">
                  <td class="py-3 px-4"><span class="font-bold text-gray-900">#${idCorto}</span></td>
                  <td class="py-3 px-4 font-black text-gray-800">${(orden.cliente_nombre || '').toUpperCase()}</td>
                  <td class="py-3 px-4 text-gray-600 font-medium">${fechaStr}</td>
                  <td class="py-3 px-4"><span class="px-2.5 py-1 rounded-md text-[10px] font-black border tracking-wider uppercase ${badgeClass}">${estadoTexto}</span></td>
                  <td class="py-3 px-4 text-right"><span class="font-black text-gray-900">${formatoPesos(orden.total_neto)}</span></td>
                  <td class="py-3 px-4 text-center">
                    <button class="text-gray-400 hover:text-orange-500 p-1"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button>
                  </td>
                </tr>
              `);
            }
          }
        });

        if (document.getElementById('carteraTotal')) document.getElementById('carteraTotal')!.textContent = formatoPesos(totalGasto);
        if (document.getElementById('carteraDeuda')) document.getElementById('carteraDeuda')!.textContent = formatoPesos(totalDeuda);
        if (document.getElementById('carteraCompras')) document.getElementById('carteraCompras')!.textContent = cantCompras.toString();

        if (tbodyCartera) tbodyCartera.innerHTML = filasHTML.length > 0 ? filasHTML.join('') : '<tr><td colspan="6" class="text-center py-8 text-gray-400 font-bold">No se encontraron facturas.</td></tr>';
        aplicarFiltroBuscadorCartera();
      };

      [selectCliente, inputRepuesto, inputPMin, inputPMax].forEach(el => el?.addEventListener('input', renderizarCartera));
      inputBuscarCartera?.addEventListener('input', aplicarFiltroBuscadorCartera);
      tbodyCartera?.addEventListener('click', (e) => {
        const row = (e.target as HTMLElement).closest('.orden-row-cartera');
        if (row) { const id = row.getAttribute('data-id'); if(id) abrirModalDetalle(id); }
      });

      // ==========================================
      // FILTROS GENERALES HISTORIAL
      // ==========================================
      const searchInput = document.getElementById('buscarOrden') as HTMLInputElement;
      const filterBtns = document.querySelectorAll('.filter-btn');
      let currentFilter = 'all';

      const aplicarFiltros = () => {
        const query = searchInput.value.toLowerCase().trim();
        const startTimestamp = filtroDesde.value ? new Date(filtroDesde.value + 'T00:00:00').getTime() : null;
        const endTimestamp = filtroHasta.value ? new Date(filtroHasta.value + 'T23:59:59').getTime() : null;

        let visiblesTotales = 0; let currentHeader: HTMLElement | null = null; let itemsInCurrentGroup = 0;

        document.querySelectorAll('#tablaOrdenes tr').forEach((row: any) => {
          if (row.classList.contains('grupo-fecha')) {
            if (currentHeader && itemsInCurrentGroup === 0) currentHeader.style.display = 'none';
            currentHeader = row; itemsInCurrentGroup = 0; row.style.display = ''; 
          } else if (row.classList.contains('orden-row')) {
            const estado = row.getAttribute('data-estado'); const cliente = row.getAttribute('data-cliente');
            const idcorto = row.getAttribute('data-idcorto'); const rowTimestamp = Number(row.getAttribute('data-timestamp'));

            const matchesSearch = cliente.includes(query) || idcorto.includes(query);
            let matchesState = false;
            if (currentFilter === 'all') matchesState = true;
            else if (currentFilter === 'completada' && estado === 'completada') matchesState = true;
            else if (currentFilter === 'cotizacion' && estado === 'cotizacion') matchesState = true;
            else if (currentFilter === 'pendiente' && (estado === 'pendiente' || row.querySelector('td:nth-child(4) span').innerText.includes('CRÉDITO'))) matchesState = true;

            let matchesDate = true;
            if (startTimestamp && rowTimestamp < startTimestamp) matchesDate = false;
            if (endTimestamp && rowTimestamp > endTimestamp) matchesDate = false;

            if (matchesSearch && matchesState && matchesDate) { row.style.display = ''; itemsInCurrentGroup++; visiblesTotales++; } 
            else { row.style.display = 'none'; }
          }
        });

        if (currentHeader && itemsInCurrentGroup === 0) currentHeader.style.display = 'none';
        if (visiblesTotales === 0) document.getElementById('noResultsMsg')?.classList.remove('hidden');
        else document.getElementById('noResultsMsg')?.classList.add('hidden');
        
        renderizarCartera();
      };

      searchInput?.addEventListener('input', aplicarFiltros);
      filtroDesde?.addEventListener('change', aplicarFiltros); filtroHasta?.addEventListener('change', aplicarFiltros);
      filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          filterBtns.forEach(b => b.className = "filter-btn px-4 py-2 bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 font-bold rounded-lg transition-colors text-sm whitespace-nowrap");
          const target = e.target as HTMLElement;
          target.className = "filter-btn active px-4 py-2 bg-gray-800 text-white font-bold rounded-lg shadow-sm text-sm whitespace-nowrap";
          currentFilter = target.getAttribute('data-estado') || 'all'; aplicarFiltros();
        });
      });

      // ==========================================
      // MODALES Y MAPEADO EXACTO PARA PDF
      // ==========================================
      const modalDetalle = document.getElementById('modalDetalle');
      const modalDetalleContainer = document.getElementById('modalDetalleContainer');
      let ordenActualSnapshot: any = null;
      let ordenActual: any = null;

      let ordenSeleccionadaId = ''; let saldoPendienteGlobal = 0; let montoRecibidoGlobal = 0; let totalNetoGlobal = 0;

      const abrirModalDetalle = (ordenId: string) => {
        const orden = window.ORDENES_DB.find((o: any) => o.id === ordenId);
        if(!orden) return;

        ordenActual = orden;

        ordenSeleccionadaId = orden.id;
        totalNetoGlobal = Number(orden.total_neto) || 0;
        montoRecibidoGlobal = Number(orden.monto_recibido) || 0;
        saldoPendienteGlobal = totalNetoGlobal - montoRecibidoGlobal;

        const idCorto = orden.id.split('-').pop().toUpperCase();
        const itemsCarrito = typeof orden.snapshot_carrito === 'string' ? JSON.parse(orden.snapshot_carrito) : (orden.snapshot_carrito || []);

        // EL SECRETO PARA EL PDF ESTÁ AQUÍ: Construir el VentaSnapshot exacto
        const itemsNormalizados = itemsCarrito.map((item: any) => ({
          cantidad: Number(item.cantidad || 1),
          precio: Number(item.precio || item.precio_venta || 0),
          descuentoTotal: Number(item.descuentoTotal || 0),
          familia: item.familia || 'REPUESTOS',
          modelo: item.modelo || item.descripcion || 'GENÉRICO'
        }));

        ordenActualSnapshot = {
          cliente: orden.cliente_nombre,
          telefono: orden.cliente_telefono && orden.cliente_telefono !== 'N/A' ? orden.cliente_telefono : '',
          fecha: new Date(orden.fecha).toLocaleDateString('es-CO') + ' ' + new Date(orden.fecha).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true }),
          items: itemsNormalizados,
          subtotal: Number(orden.subtotal || 0),
          descuentoGlobal: Number(orden.descuento_global || 0),
          totalNeto: totalNetoGlobal,
          recibido: montoRecibidoGlobal,
          tipoVenta: orden.estado === 'cotizacion' ? 'cotizacion' : (orden.tipo_venta || 'contado'),
          metodoPago: orden.metodo_pago || 'efectivo',
          numeroComprobante: idCorto
        };

        document.getElementById('detIdOrden')!.innerText = `REF: ${idCorto}`;
        document.getElementById('detCliente')!.innerText = orden.cliente_nombre;
        document.getElementById('detTelefono')!.innerText = `TEL: ${orden.cliente_telefono || 'N/A'}`;
        document.getElementById('detFecha')!.innerText = ordenActualSnapshot.fecha;
        document.getElementById('detMetodo')!.innerText = `Pago: ${orden.metodo_pago}`;
        document.getElementById('detSubtotal')!.innerText = formatoPesos(orden.subtotal);
        document.getElementById('detDescuento')!.innerText = `-${formatoPesos(orden.descuento_global)}`;
        document.getElementById('detTotalNeto')!.innerText = formatoPesos(totalNetoGlobal);

        const badge = document.getElementById('detEstadoBadge')!;
        badge.className = "px-2.5 py-1 rounded-md text-[11px] font-black border tracking-wider uppercase";
        
        const containerAbono = document.getElementById('detAbonadoContainer')!;
        const containerSaldo = document.getElementById('detSaldoContainer')!;
        const btnAbonar = document.getElementById('btnRegistrarAbono')!;

        containerAbono.classList.add('hidden'); containerSaldo.classList.add('hidden');
        btnAbonar.classList.add('hidden'); btnAbonar.style.display = ''; 

        if (orden.estado === 'completada') {
          badge.classList.add("bg-green-100", "text-green-700", "border-green-200"); badge.innerText = "Completada";
        } else if (orden.estado === 'cotizacion') {
          badge.classList.add("bg-blue-100", "text-blue-700", "border-blue-200"); badge.innerText = "Cotización";
        } else if (orden.estado === 'pendiente') {
          badge.classList.add("bg-orange-100", "text-orange-700", "border-orange-200"); badge.innerText = orden.tipo_venta === 'credito' ? 'Crédito' : 'Pendiente';
          if (totalNetoGlobal > 0) {
            document.getElementById('detAbonado')!.innerText = formatoPesos(montoRecibidoGlobal); document.getElementById('detSaldo')!.innerText = formatoPesos(saldoPendienteGlobal);
            containerAbono.classList.remove('hidden'); containerSaldo.classList.remove('hidden'); btnAbonar.classList.remove('hidden');
          }
        }

        const tbody = document.getElementById('detItemsTbody')!; tbody.innerHTML = '';
        if(itemsNormalizados.length === 0) {
           tbody.innerHTML = '<tr><td colspan="4" class="py-4 text-center text-gray-400 text-xs">Sin detalle</td></tr>';
        } else {
          itemsNormalizados.forEach((item: any) => {
             const subtotalLinea = (item.precio * item.cantidad) - item.descuentoTotal;
            tbody.innerHTML += `
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-2 px-3 font-bold text-gray-700 align-top">${item.cantidad}</td>
                <td class="py-2 px-3 align-top">
                  <p class="font-bold text-gray-800 uppercase text-xs leading-tight">${item.familia}</p>
                  <p class="text-[10px] text-gray-500 uppercase mt-0.5">Ref: ${item.modelo}</p>
                </td>
                <td class="py-2 px-3 text-right text-gray-600 font-medium align-top">${formatoPesos(item.precio)}</td>
                <td class="py-2 px-3 text-right font-black text-gray-900 align-top">${formatoPesos(subtotalLinea)}</td>
              </tr>`;
          });
        }

        modalDetalle?.classList.remove('hidden');
        requestAnimationFrame(() => { modalDetalle?.classList.remove('opacity-0'); document.getElementById('modalDetalleContainer')?.classList.remove('scale-95'); });
      };

      // ==========================================
      // MANEJO DE ABONOS Y BOTONES PDF
      // ==========================================
      const modalAbono = document.getElementById('modalAbono'); const modalAbonoBox = document.getElementById('modalAbonoBox');
      const inputMontoAbono = document.getElementById('inputMontoAbono') as HTMLInputElement;

      inputMontoAbono?.addEventListener('input', function(e) {
        let valorRaw = this.value.replace(/\D/g, ''); if (!valorRaw) { this.value = ''; return; }
        this.value = Number(valorRaw).toLocaleString('es-CO');
      });

      document.getElementById('btnRegistrarAbono')?.addEventListener('click', () => {
        document.getElementById('abonoSaldoFaltante')!.innerText = formatoPesos(saldoPendienteGlobal); inputMontoAbono.value = ''; 
        modalAbono?.classList.remove('hidden');
        requestAnimationFrame(() => { modalAbono?.classList.remove('opacity-0'); modalAbonoBox?.classList.remove('scale-95'); });
      });

      document.getElementById('btnAbonarTodo')?.addEventListener('click', () => inputMontoAbono.value = saldoPendienteGlobal.toLocaleString('es-CO'));
      document.getElementById('closeAbono')?.addEventListener('click', () => {
        modalAbono?.classList.add('opacity-0'); modalAbonoBox?.classList.add('scale-95');
        setTimeout(() => modalAbono?.classList.add('hidden'), 200);
      });

      document.getElementById('btnConfirmarAbono')?.addEventListener('click', async () => {
        const montoIngresado = Number(inputMontoAbono.value.replace(/\D/g, ''));
        if (montoIngresado <= 0) return alert('Ingresa un monto válido mayor a cero.');
        if (montoIngresado > saldoPendienteGlobal) return alert('El monto no puede ser mayor al saldo pendiente.');

        const btn = document.getElementById('btnConfirmarAbono') as HTMLButtonElement; const textoOriginal = btn.innerHTML;
        btn.innerHTML = 'Procesando...'; btn.disabled = true;

        const nuevoMontoRecibido = montoRecibidoGlobal + montoIngresado;
        const nuevoEstado = (nuevoMontoRecibido >= totalNetoGlobal) ? 'completada' : 'pendiente';

        try {
          const { error } = await supabase.from('ventas').update({ monto_recibido: nuevoMontoRecibido, estado: nuevoEstado }).eq('id', ordenSeleccionadaId);
          if (error) throw error; window.location.reload();
        } catch (error) { alert("Error al procesar el pago."); btn.innerHTML = textoOriginal; btn.disabled = false; }
      });

      const cerrarModal = () => {
        modalDetalle?.classList.add('opacity-0'); modalDetalleContainer?.classList.add('scale-95');
        setTimeout(() => modalDetalle?.classList.add('hidden'), 300);
      };
      document.querySelectorAll('.orden-row').forEach(row => { row.addEventListener('click', () => { const id = row.getAttribute('data-id'); if(id) abrirModalDetalle(id); }); });
      document.getElementById('closeDetalle')?.addEventListener('click', cerrarModal);

      // --- DISPARADOR DEL PDF ---
      const ejecutarPDF = async (btn: HTMLButtonElement, accion: 'descargar' | 'imprimir') => {
        if(!ordenActualSnapshot) return;
        const textoOriginal = btn.innerHTML;
        btn.innerHTML = `<svg class="animate-spin h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Procesando...`;
        btn.disabled = true;
        
        try {
          await generarFacturaPDF(ordenActualSnapshot, accion);
        } catch (error) {
          console.error("Error al generar PDF:", error);
          alert("Error interno al cargar la librería de PDF.");
        } finally {
          btn.innerHTML = textoOriginal; btn.disabled = false;
        }
      };

      const obtenerOrdenActual = () => {
        if (!ordenSeleccionadaId || !window.ORDENES_DB) return null;
        return window.ORDENES_DB.find((o: any) => o.id === ordenSeleccionadaId) || null;
      };

      const marcarDeudaComoSaldada = async (btn: HTMLButtonElement) => {
        const ordenActual = obtenerOrdenActual();
        if (!ordenActual) {
          console.error('No se encontró la orden actual para saldar.');
          return;
        }

        const idCorto = ordenActual.id?.split('-').pop()?.substring(6)?.toUpperCase() || 'N/A';
        const confirmar = confirm(`¿Estás seguro de marcar la orden #${idCorto} como totalmente PAGADA?`);
        if (!confirmar) return;

        const textoOriginal = btn.innerHTML;
        btn.innerHTML = 'Procesando...';
        btn.disabled = true;

        try {
          const payload: any = {
            estado: 'completada',
            tipo_venta: 'contado',
            monto_recibido: Number(ordenActual.total_neto) || 0,
            abono: Number(ordenActual.total_neto) || 0,
          };

          let { error } = await supabase
            .from('ventas')
            .update(payload)
            .eq('id', ordenActual.id);

          // Compatibilidad si la tabla no tiene la columna `abono`.
          if (error && String(error.message || '').toLowerCase().includes('abono')) {
            ({ error } = await supabase
              .from('ventas')
              .update({
                estado: 'completada',
                tipo_venta: 'contado',
                monto_recibido: Number(ordenActual.total_neto) || 0,
              })
              .eq('id', ordenActual.id));
          }

          if (error) throw error;

          alert('¡Deuda saldada con éxito!');
          window.location.reload();
        } catch (error) {
          console.error('Error al saldar la deuda:', error);
          alert('Hubo un error al actualizar la base de datos.');
          btn.innerHTML = textoOriginal;
          btn.disabled = false;
        }
      };

      document.getElementById('btnHistorialDescargar')?.addEventListener('click', function() { ejecutarPDF(this as HTMLButtonElement, 'descargar'); });
      document.getElementById('btnHistorialImprimir')?.addEventListener('click', function() { ejecutarPDF(this as HTMLButtonElement, 'imprimir'); });

      const btnEditarFactura = document.getElementById('btnEditarFactura');
      if (btnEditarFactura) {
        btnEditarFactura.addEventListener('click', () => {
          if (typeof ordenActual !== 'undefined' && ordenActual) {
            localStorage.setItem('facturaEnEdicion', JSON.stringify(ordenActual));
            window.location.href = '/pos/ventas';
          }
        });
      }

      // Compatibilidad con IDs alternos usados en otros modales.
      const btnImprimir = document.getElementById('btnImprimir') as HTMLButtonElement | null;
      const btnDescargar = document.getElementById('btnDescargar') as HTMLButtonElement | null;
      const btnSaldar = document.getElementById('btnSaldar') as HTMLButtonElement | null;

      if (btnImprimir) {
        btnImprimir.addEventListener('click', () => ejecutarPDF(btnImprimir, 'imprimir'));
      }

      if (btnDescargar) {
        btnDescargar.addEventListener('click', () => ejecutarPDF(btnDescargar, 'descargar'));
      }

      if (btnSaldar) {
        btnSaldar.addEventListener('click', () => {
          marcarDeudaComoSaldada(btnSaldar);
        });
      }

      // --- CONECTAR CARTERA CON EL MODAL DEL HISTORIAL ---
      document.querySelectorAll('.fila-cartera').forEach(row => {
        row.addEventListener('click', () => {
          const id = row.getAttribute('data-id');
          if (id && typeof abrirModalDetalle === 'function') {
            abrirModalDetalle(id);
          }
        });
      });

      // Navegación
      (function() {
        const currentPath = window.location.pathname.replace(/\/$/, ""); 
        document.querySelectorAll('.nav-link').forEach(link => {
          const href = link.getAttribute('href')?.replace(/\/$/, ""); 
          if ((href === '/pos' ? currentPath === '/pos' : currentPath.includes(href || ''))) {
            link.classList.remove('text-gray-300', 'border-transparent', 'hover:bg-gray-800', 'hover:text-white');
            link.classList.add('bg-gray-800', 'text-orange-400', 'border-gray-700', 'shadow-inner');
          }
        });
      })();
    </script>
  </body>
</html>