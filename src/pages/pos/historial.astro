---
import '../../styles.css';
import { supabase } from '../../lib/supabase.js';

// Obtenemos las órdenes ordenadas desde la más reciente
const { data: ordenesData, error } = await supabase
  .from('ventas')
  .select('*')
  .order('fecha', { ascending: false });

const ordenes = ordenesData || [];

// 1. LÓGICA DE AGRUPACIÓN POR FECHA
const ordenesAgrupadas = ordenes.reduce((acc, orden) => {
  const fechaObj = new Date(orden.fecha);
  const diaStr = fechaObj.toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'short', year: 'numeric' });
  const clave = diaStr.charAt(0).toUpperCase() + diaStr.slice(1); 
  
  if (!acc[clave]) acc[clave] = [];
  acc[clave].push(orden);
  return acc;
}, {});

const formatoPesos = (num) => '$' + Math.round(num).toLocaleString('es-CO');
const formatearHora = (isoString) => {
  if (!isoString) return '--:--';
  return new Date(isoString).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true });
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Historial y Cartera - Premium Racing</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="apple-touch-icon" href="/icono-192.png" />
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" is:inline></script>
    <script is:inline>
      window.jsPDF = window.jspdf.jsPDF;
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js" is:inline></script>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
      body {
        font-family: 'Inter', sans-serif;
        background: #e6e7ee;
        min-height: 100vh;
        color: #2d3748;
        overflow-x: hidden;
      }
      .page-bg {
        position: fixed; inset: 0; z-index: -10;
        background: radial-gradient(circle at top, rgba(255, 107, 53, 0.18), transparent 55%),
          radial-gradient(circle at 25% 30%, rgba(45, 55, 72, 0.25), transparent 50%),
          linear-gradient(135deg, #e6e7ee 0%, #f6f7fb 100%);
      }
      .neumorphism {
        background: #e6e7ee;
        box-shadow: 10px 10px 20px #bebebe, -10px -10px 20px #ffffff;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.6);
      }
      .neumorphism-inset {
        background: #e6e7ee;
        box-shadow: inset 5px 5px 10px #bebebe, inset -5px -5px 10px #ffffff;
        border-radius: 15px;
      }
      .search-input, .filter-input {
        width: 100%;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.85);
        box-shadow: inset 4px 4px 8px rgba(0,0,0,0.05);
        outline: none;
      }
      .search-input:focus, .filter-input:focus {
        border-color: rgba(255, 107, 53, 0.6);
        box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.15);
      }
      .layout-height {
        height: calc(100vh - 5rem); 
      }
      .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
      .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
  </head>
  <body>
    <div class="page-bg"></div>

    <header class="w-full h-16 bg-gray-900 shadow-lg border-b-4 border-orange-500 relative z-10 flex items-center shrink-0">
      <div class="w-full max-w-[98%] mx-auto px-4 flex justify-between items-center">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg overflow-hidden shrink-0 border border-gray-700">
            <img src="/logo.png" alt="Premium Racing" class="w-full h-full object-contain p-1" onerror="this.src='https://placehold.co/100x100?text=PR'" />
          </div>
          <div class="hidden lg:block">
            <h1 class="text-xl font-bold text-white tracking-wide leading-tight">Premium Racing</h1>
            <p class="text-orange-400 text-[10px] font-black uppercase tracking-widest">Sistema de Gestión</p>
          </div>
        </div>

        <nav class="flex items-center gap-1 md:gap-2 overflow-x-auto whitespace-nowrap custom-scrollbar pb-1 md:pb-0">
          <a href="/pos/inicio" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
            <span class="hidden md:inline">Inicio</span>
          </a>
          <a href="/pos/ventas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            <span class="hidden md:inline">Ventas</span>
          </a>
          <a href="/pos/historial" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="hidden md:inline">Historial</span>
          </a>

          <a href="/pos" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="hidden md:inline">Inventario</span>
          </a>

          <a href="/pos/estadisticas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            <span class="hidden md:inline">Estadísticas</span>
          </a>
        </nav>

        <div class="hidden sm:block ml-2 pl-2 md:ml-4 md:pl-4 border-l border-gray-700 shrink-0">
           <button class="text-gray-400 hover:text-red-400 transition-colors p-2 rounded-lg hover:bg-gray-800" title="Cerrar Sesión">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
               <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
             </svg>
           </button>
        </div>
      </div>
    </header>

    <main class="max-w-[98%] mx-auto py-4 layout-height flex flex-col gap-4">
      
      <div class="flex flex-col md:flex-row gap-4 justify-between items-center mb-1 shrink-0 border-b-2 border-gray-300/50 pb-2 px-2">
        <div class="flex gap-6 w-full md:w-auto">
          <button id="tabOrdenes" class="text-orange-600 font-black border-b-4 border-orange-500 pb-2 px-2 transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            Historial General
          </button>
          <button id="tabCartera" class="text-gray-500 font-bold border-b-4 border-transparent hover:text-orange-500 pb-2 px-2 transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            Cartera de Clientes
          </button>
        </div>

        <div class="flex items-center bg-white border border-gray-200 rounded-full px-4 shadow-sm h-[42px] overflow-hidden w-full md:w-auto">
          <span class="text-xs font-bold text-gray-400 mr-2 uppercase tracking-wider">De:</span>
          <input type="date" id="filtroDesde" class="bg-transparent text-sm text-gray-700 outline-none font-medium w-full md:w-auto" />
          <span class="text-gray-300 mx-2">|</span>
          <span class="text-xs font-bold text-gray-400 mr-2 uppercase tracking-wider">A:</span>
          <input type="date" id="filtroHasta" class="bg-transparent text-sm text-gray-700 outline-none font-medium w-full md:w-auto" />
        </div>
      </div>

      <div id="vistaOrdenes" class="flex-1 flex flex-col gap-4 overflow-hidden">
        <section class="neumorphism p-4 shrink-0 flex flex-col md:flex-row gap-4 items-center justify-between">
          <div class="relative w-full md:max-w-xs">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </span>
            <input type="text" id="buscarOrden" placeholder="Buscar cliente o ID..." class="search-input bg-white/60" style="padding-left: 2.8rem;" />
          </div>

          <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-1 md:pb-0 shrink-0">
            <button class="filter-btn active px-4 py-2 bg-gray-800 text-white font-bold rounded-lg shadow-sm text-sm whitespace-nowrap" data-estado="all">Todas</button>
            <button class="filter-btn px-4 py-2 bg-white text-gray-600 border border-gray-200 hover:bg-green-50 hover:text-green-700 font-bold rounded-lg transition-colors text-sm whitespace-nowrap" data-estado="completada">Completadas</button>
            <button class="filter-btn px-4 py-2 bg-white text-gray-600 border border-gray-200 hover:bg-blue-50 hover:text-blue-700 font-bold rounded-lg transition-colors text-sm whitespace-nowrap" data-estado="cotizacion">Cotizaciones</button>
            <button class="filter-btn px-4 py-2 bg-white text-gray-600 border border-gray-200 hover:bg-orange-50 hover:text-orange-700 font-bold rounded-lg transition-colors text-sm whitespace-nowrap" data-estado="pendiente">Pendientes</button>
          </div>
        </section>

        <section class="neumorphism p-4 flex-1 flex flex-col overflow-hidden bg-white/30">
          <div class="w-full overflow-x-auto custom-scrollbar flex-1 rounded-xl border border-gray-200 bg-white">
            <table class="w-full min-w-[800px] text-left text-sm whitespace-nowrap">
              <thead class="bg-gray-50 border-b border-gray-200 sticky top-0 z-10">
                <tr>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs">Ref Orden</th>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs">Fecha y Hora</th>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs">Cliente</th>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs">Estado</th>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs text-right">Total Neto</th>
                  <th class="py-3 px-4 font-black text-gray-500 uppercase tracking-wider text-xs text-center">Acción</th>
                </tr>
              </thead>
              <tbody id="tablaOrdenes" class="divide-y divide-gray-100">
                {Object.entries(ordenesAgrupadas).flatMap(([diaString, grupoOrdenes]) => {
                  const filas = [];
                  filas.push(
                    <tr class="grupo-fecha bg-gray-100/80 border-y border-gray-300">
                      <td colspan="6" class="py-2.5 px-4 text-xs font-black text-gray-800 uppercase tracking-widest">{diaString}</td>
                    </tr>
                  );
                  grupoOrdenes.forEach((orden) => {
                    let badgeClass = "bg-gray-100 text-gray-700";
                    let estadoTexto = orden.estado.toUpperCase();
                    
                    if (orden.estado === 'completada') badgeClass = "bg-green-100 text-green-700 border-green-200";
                    else if (orden.estado === 'cotizacion') badgeClass = "bg-blue-100 text-blue-700 border-blue-200";
                    else if (orden.estado === 'pendiente' || orden.tipo_venta === 'credito') {
                      badgeClass = "bg-orange-100 text-orange-700 border-orange-200";
                      if(orden.tipo_venta === 'credito') estadoTexto = 'CRÉDITO';
                    }

                    const idCorto = orden.id ? orden.id.split('-').pop().substring(6).toUpperCase() : 'N/A';
                    const timestampObj = new Date(orden.fecha).getTime();

                    filas.push(
                      <tr class="orden-row hover:bg-orange-50/50 transition-colors group cursor-pointer" 
                          data-id={orden.id} data-estado={orden.estado} data-cliente={orden.cliente_nombre.toLowerCase()} 
                          data-idcorto={idCorto.toLowerCase()} data-timestamp={timestampObj}>
                        <td class="py-3 px-4"><span class="font-bold text-gray-900">#{idCorto}</span></td>
                        <td class="py-3 px-4 text-gray-600 font-medium">{formatearHora(orden.fecha)}</td>
                        <td class="py-3 px-4">
                          <div class="flex flex-col">
                            <span class="font-black text-gray-800">{orden.cliente_nombre.toUpperCase()}</span>
                            {orden.cliente_telefono && orden.cliente_telefono !== 'N/A' && (
                              <span class="text-[10px] text-gray-500 font-bold">{orden.cliente_telefono}</span>
                            )}
                          </div>
                        </td>
                        <td class="py-3 px-4"><span class={`px-2.5 py-1 rounded-md text-[10px] font-black border tracking-wider uppercase ${badgeClass}`}>{estadoTexto}</span></td>
                        <td class="py-3 px-4 text-right"><span class="font-black text-gray-900">{formatoPesos(orden.total_neto)}</span></td>
                        <td class="py-3 px-4 text-center">
                          <button class="text-gray-400 hover:text-orange-500 p-1" title="Ver Detalles">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                          </button>
                        </td>
                      </tr>
                    );
                  });
                  return filas;
                })}
                {ordenes.length === 0 && (<tr><td colspan="6" class="py-8 text-center text-gray-500 font-medium">No hay órdenes registradas.</td></tr>)}
              </tbody>
            </table>
            <div id="noResultsMsg" class="hidden py-8 text-center text-gray-500 font-medium border-t border-gray-100">
              No se encontraron órdenes.
            </div>
          </div>
        </section>
      </div>

      <div id="vistaCartera" class="hidden flex-1 flex flex-col gap-4 overflow-hidden">
        <div class="bg-white p-3 rounded-xl border border-gray-200 shadow-sm shrink-0 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input type="text" id="inputBuscarCartera" placeholder="Filtrar por nombre de cliente..." class="w-full outline-none text-sm font-medium text-gray-700 bg-transparent placeholder-gray-400" />
        </div>

        <section class="neumorphism p-4 shrink-0 grid grid-cols-1 md:grid-cols-4 gap-4 items-center">
          <div class="col-span-1 md:col-span-1">
            <select id="selectCarteraCliente" class="filter-input bg-white/60 font-bold text-gray-700 cursor-pointer">
              <option value="">-- Seleccionar Cliente --</option>
            </select>
          </div>
          <div class="col-span-1 md:col-span-1 relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">🔍</span>
            <input type="text" id="filtroRepuesto" placeholder="Contiene Repuesto (Ej: Filtro)" class="filter-input bg-white/60" style="padding-left: 2.5rem;" />
          </div>
          <div class="col-span-1 md:col-span-2 flex items-center gap-2">
            <input type="number" id="filtroPrecioMin" placeholder="Precio Min ($)" class="filter-input bg-white/60 text-sm" />
            <span class="text-gray-400 font-bold">-</span>
            <input type="number" id="filtroPrecioMax" placeholder="Precio Max ($)" class="filter-input bg-white/60 text-sm" />
          </div>
        </section>

        <section id="statsCartera" class="hidden shrink-0 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="neumorphism p-4 bg-white/50 border-l-4 border-green-500">
            <p class="text-[10px] font-black uppercase text-gray-500 tracking-widest">Total Comprado</p>
            <p class="text-2xl font-black text-gray-900 mt-1" id="carteraTotal">$0</p>
          </div>
          <div class="neumorphism p-4 bg-white/50 border-l-4 border-orange-500">
            <p class="text-[10px] font-black uppercase text-gray-500 tracking-widest">Deuda Pendiente</p>
            <p class="text-2xl font-black text-orange-600 mt-1" id="carteraDeuda">$0</p>
          </div>
          <div class="neumorphism p-4 bg-white/50 border-l-4 border-blue-500">
            <p class="text-[10px] font-black uppercase text-gray-500 tracking-widest">Cantidad de Facturas</p>
            <p class="text-2xl font-black text-gray-900 mt-1" id="carteraCompras">0</p>
          </div>
        </section>

        <section class="neumorphism p-4 flex-1 flex flex-col overflow-hidden bg-white/30">
          <div class="w-full overflow-x-auto custom-scrollbar flex-1 rounded-xl border border-gray-200 bg-white">
            <table class="w-full min-w-[800px] text-left text-sm whitespace-nowrap">
              <thead class="bg-gray-800 text-white sticky top-0 z-10">
                <tr>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs">ID Factura / Ref</th>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs">Cliente</th>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs">Fecha y Hora</th>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs">Estado</th>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs text-right">Total Neto</th>
                  <th class="py-3 px-4 font-black uppercase tracking-wider text-xs text-center">Acciones</th>
                </tr>
              </thead>
              <tbody id="tablaCarteraItems" class="divide-y divide-gray-100">
                <tr><td colspan="6" class="text-center py-8 text-gray-400 font-bold">Selecciona un cliente arriba para ver sus facturas.</td></tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </main>

    <div id="modalDetalle" class="hidden fixed inset-0 bg-neutral-950/80 z-[200] backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
      <div class="neumorphism w-full max-w-3xl bg-[#e6e7ee] rounded-[2rem] flex flex-col overflow-hidden border border-white/50 shadow-2xl scale-95 transition-transform duration-300 max-h-[90vh]" id="modalDetalleContainer">
        
        <div class="bg-gray-900 text-white px-6 py-4 flex justify-between items-center border-b-4 border-orange-500 shrink-0">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center border border-gray-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-black tracking-wide leading-tight">Detalle de Documento</h2>
