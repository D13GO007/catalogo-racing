        <div class="flex justify-center gap-4 mt-6 pt-4 border-t border-gray-300">
          <button id="btnCancelDelete" class="neumorphism-button px-5 py-2 text-gray-600 font-bold hover:text-gray-900 transition-colors">
            Cancelar
          </button>
          <button id="btnConfirmDelete" class="neumorphism-button px-5 py-2 text-white font-bold hover:bg-red-700 transition-colors" style="background: #dc2626;">
            Sí, Eliminar
          </button>
        </div>
