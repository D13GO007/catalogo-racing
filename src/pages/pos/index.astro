---
// Importamos tus estilos globales (subiendo dos carpetas: de pos -> pages -> src)
import '../../styles.css'; 
import { supabase } from '../../lib/supabase.js';
import posClientUrl from '../../lib/pos-client.ts?url';

// Traemos el inventario

type Familia = { id: string | number; nombre: string };

type Referencia = {
  id: string | number;
  modelo: string;
  precio_venta: number;
  precio_costo: number;
  stock_actual: number;
  visible_en_catalogo: boolean;
  imagen_especifica?: string;
  familias?: Familia | null;
};

const { data: referenciasRaw, error } = await supabase
  .from<Referencia>('referencias')
  .select(`
    id,
    modelo,
    precio_venta,
    precio_costo,
    stock_actual,
    visible_en_catalogo,
    imagen_especifica,
    familias ( id, nombre )
  `)
  .eq('activo', true)                // <--- 1. Oculta los "Eliminados"
  // Nota: en el panel de administración mostramos todos los ítems (incluso los que aún no están visibles en el catálogo público)
  .order('modelo');

const referencias: Referencia[] = (referenciasRaw ?? []) as Referencia[];

const familias = Array.from(
  new Map(
    referencias
      .map(r => r.familias)
      .filter(Boolean)
      .map(f => [f.id, f] as [string | number, Familia])
  ).values()
).sort((a, b) => a.nombre.localeCompare(b.nombre));

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Tiendana - Premium Racing</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="apple-touch-icon" href="/icono-192.png" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
      body {
        font-family: 'Inter', sans-serif;
        background: #e6e7ee;
        min-height: 100vh;
        color: #2d3748;
        position: relative;
        overflow-x: hidden;
      }
      .page-bg {
        position: fixed;
        inset: 0;
        z-index: -10;
        background: radial-gradient(circle at top, rgba(255, 107, 53, 0.18), transparent 55%),
          radial-gradient(circle at 25% 30%, rgba(45, 55, 72, 0.25), transparent 50%),
          linear-gradient(135deg, #e6e7ee 0%, #f6f7fb 100%);
      }
      .page-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg width='400' height='400' viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop stop-color='%23ff6b35' stop-opacity='0.07'/%3E%3Cstop offset='1' stop-color='%23ff6b35' stop-opacity='0'/%3E%3C/linearGradient%3E%3C/defs%3E%3Ccircle cx='200' cy='200' r='200' fill='url(%23g)'/%3E%3C/svg%3E");
        opacity: 0.25;
      }
      .neumorphism {
        background: #e6e7ee;
        box-shadow: 20px 20px 40px #bebebe, -20px -20px 40px #ffffff;
        border-radius: 20px;
      }
      .neumorphism-inset {
        background: #e6e7ee;
        box-shadow: inset 10px 10px 20px #bebebe, inset -10px -10px 20px #ffffff;
        border-radius: 15px;
      }
      .neumorphism-button {
        background: #e6e7ee;
        box-shadow: 5px 5px 10px #bebebe, -5px -5px 10px #ffffff;
        border-radius: 10px;
        transition: all 0.25s ease;
      }
      .neumorphism-button:hover {
        box-shadow: inset 5px 5px 10px #bebebe, inset -5px -5px 10px #ffffff;
        transform: translateY(2px);
      }
      .neumorphism-card {
        background: #e6e7ee;
        box-shadow: 10px 10px 20px #bebebe, -10px -10px 20px #ffffff;
        border-radius: 20px;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.6);
      }
      .neumorphism-card:hover {
        box-shadow: 16px 16px 32px rgba(0, 0, 0, 0.12), -16px -16px 32px rgba(255, 255, 255, 0.7);
        transform: translateY(-5px);
      }
      .glow-text {
        text-shadow: 0 0 12px rgba(255, 165, 0, 0.5);
      }
      .header-gradient {
        position: relative;
        background: linear-gradient(135deg, rgba(45, 55, 72, 0.95) 0%, rgba(255, 107, 53, 0.9) 100%);
        background-size: 400% 400%;
        animation: headerGradient 12s ease infinite;
        color: white;
        border-radius: 0;
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.22);
      }

      @keyframes headerGradient {
        0% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
        100% {
          background-position: 0% 50%;
        }
      }
      .card-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.22rem 0.8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.90);
        border: 1px solid rgba(255, 107, 53, 0.35);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
        backdrop-filter: blur(6px);
        color: #b34708;
        font-weight: 700;
        font-size: 0.82rem;
        text-shadow: 0 0 4px rgba(255, 255, 255, 0.75);
      }
      .search-input {
        width: 100%;
        max-width: 420px;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.2);
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 12px 20px rgba(0, 0, 0, 0.12);
        outline: none;
        transition: all 0.2s ease;
        font-weight: 600;
        color: #1f2937;
        letter-spacing: 0.02em;
      }
      .search-input.pl-10 {
        padding-left: 2.5rem;
      }
      .search-input::placeholder {
        color: rgba(55, 65, 81, 0.65);
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .search-input:focus {
        border-color: rgba(255, 107, 53, 0.8);
        box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.18);
      }
    </style>
  </head>
  <body class="text-gray-800 min-h-screen" data-supabase-url={SUPABASE_URL} data-supabase-anon-key={SUPABASE_ANON_KEY}>
    <div class="page-bg"></div>

    <header class="w-full h-16 bg-gray-900 shadow-lg border-b-4 border-orange-500 relative z-10 flex items-center shrink-0">
      <div class="w-full max-w-[98%] mx-auto px-4 flex justify-between items-center">
        
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg overflow-hidden shrink-0 border border-gray-700">
            <img src="/logo.png" alt="Premium Racing" class="w-full h-full object-contain p-1" onerror="this.src='https://placehold.co/100x100?text=PR'" />
          </div>
          <div class="hidden lg:block">
            <h1 class="text-xl font-bold text-white tracking-wide leading-tight">Premium Racing</h1>
            <p class="text-orange-400 text-[10px] font-black uppercase tracking-widest">Sistema de Gestión</p>
          </div>
        </div>

        <nav class="flex gap-1 md:gap-2 overflow-x-auto custom-scrollbar pb-1 md:pb-0">
          <a href="/pos/inicio" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="hidden md:inline">Inicio</span>
          </a>
          <a href="/pos/ventas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span class="hidden md:inline">Ventas</span>
          </a>

          <a href="/pos/historial" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="hidden md:inline">Historial</span>
          </a>

          <a href="/pos" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="hidden md:inline">Inventario</span>
          </a>

          <a href="/pos/estadisticas" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            <span class="hidden md:inline">Estadísticas</span>
          </a>
        </nav>
        
        <div class="hidden sm:block ml-2 pl-2 md:ml-4 md:pl-4 border-l border-gray-700 shrink-0">
           <button class="text-gray-400 hover:text-red-400 transition-colors p-2 rounded-lg hover:bg-gray-800" title="Cerrar Sesión">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
               <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
             </svg>
           </button>
        </div>

      </div>
    </header>

    <main class="max-w-[98%] mx-auto py-4 flex flex-col gap-4 h-[calc(100vh-5rem)]">
      {error && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-red-700">
          <strong>Error cargando productos:</strong> {error.message || error.details || JSON.stringify(error)}
        </div>
      )}

      <section class="hidden md:flex w-full h-full">
        <aside class="w-72 flex-shrink-0 h-full">
          <div class="neumorphism p-4 h-full overflow-y-auto">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-600">Repuestos</h3>
              <button
                id="clearFilter"
                class="text-xs text-orange-600 hover:text-orange-700"
                type="button"
              >
                Limpiar
              </button>
            </div>
            <div class="space-y-2">
              <button
                type="button"
                data-family="all"
                class="family-btn w-full text-left px-3 py-2 rounded-lg border border-gray-200 bg-white text-gray-700 font-medium hover:bg-orange-50 transition"
              >
                TODAS
              </button>
              {familias.map(fam => (
                <button
                  type="button"
                  data-family={fam.nombre}
                  class="family-btn w-full text-left px-3 py-2 rounded-lg border border-gray-200 bg-white text-gray-700 font-medium hover:bg-orange-50 transition"
                >
                  {fam.nombre.toUpperCase()}
                </button>
              ))}
            </div>
          </div>
        </aside>

        <div class="flex-1 px-6 py-4 h-full flex flex-col gap-4">
          <div class="relative w-full md:max-w-md shrink-0">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-orange-500 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </span>
            <input
              id="searchInput"
              type="search"
              placeholder="Buscar modelo, código o categoría..."
              class="w-full bg-white/60 backdrop-blur-sm border border-white/50 text-gray-800 text-sm font-bold shadow-sm focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-500/10 rounded-full transition-all outline-none"
              style="padding: 0.8rem 1rem 0.8rem 3.2rem;"
            />
          </div>

          <div class="flex-1 overflow-y-auto custom-scrollbar pb-24 pr-2">
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" id="cardGridDesktop">
              {referencias?.length ? (
                referencias.map((ref) => (
                  <div
                    class="neumorphism-card p-2 inventory-card cursor-pointer"
                    data-id={ref.id}
                    data-modelo={ref.modelo}
                    data-familia-id={ref.familias?.id}
                    data-family={ref.familias?.nombre?.toUpperCase()}
                    data-venta={ref.precio_venta}
                    data-costo={ref.precio_costo}
                    data-stock={ref.stock_actual}
                    data-imagen={ref.imagen_especifica}
                  >
                    <div class="relative mb-2">
                      <div class="relative overflow-hidden rounded-xl neumorphism-inset bg-white">
                        <img
                          src={ref.imagen_especifica || 'https://placehold.co/400x400?text=Sin+imagen'}
                          alt={ref.modelo}
                          class="w-full h-36 object-contain p-2 bg-gradient-to-br from-white via-white to-orange-50"
                        />
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/10" />
                      </div>
                      <div class="absolute top-3 left-3 card-tag">
                        <span class="text-xs uppercase tracking-widest">{ref.familias?.nombre?.toUpperCase() || 'SIN FAMILIA'}</span>
                      </div>
                    </div>
                    <div class="flex justify-between items-start mb-2">
                      <div>
                        <h3 class="font-bold text-gray-900 text-lg">{ref.modelo.toUpperCase()}</h3>
                        <p class="text-gray-500 text-xs">ID: {String(ref.id).slice(-6)}</p>
                      </div>
                    </div>
                    <div class="space-y-1">
                      <div class="flex justify-between">
                        <span class="text-gray-700 font-semibold text-sm">PRECIO VENTA:</span>
                        <span class="text-gray-900 font-extrabold text-base">${ref.precio_venta.toLocaleString('es-CO')}</span>
                      </div>
                      <div class="flex justify-between items-center">
                        <span class="text-gray-700 font-semibold text-sm">STOCK:</span>
                        <span class={`px-2 py-1 rounded-full text-sm font-semibold ${ref.stock_actual > 10 ? 'bg-green-100 text-green-800' : ref.stock_actual > 0 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800'}`}>
                          {ref.stock_actual}
                        </span>
                      </div>
                    </div>
                  </div>
                ))
              ) : (
                <div class="col-span-full rounded-lg border border-dashed border-gray-300 bg-white/60 p-6 text-center text-gray-600">
                  No se encontraron productos para mostrar.
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="block md:hidden flex-1 overflow-y-auto pb-20 custom-scrollbar">
        <div class="flex flex-col gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-100 shrink-0">
          <h2 class="text-orange-600 font-black text-xl flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Inventario Premium
          </h2>

          <div class="flex flex-col sm:flex-row w-full items-center gap-3">
            <div class="bg-gray-50 p-2.5 rounded-xl border border-gray-200 flex items-center gap-2 w-full focus-within:ring-2 focus-within:ring-orange-500 focus-within:border-orange-500 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input type="text" id="inputBuscarInventario" placeholder="Buscar referencia o modelo..." class="w-full bg-transparent outline-none text-sm font-medium text-gray-700 placeholder-gray-400" />
            </div>

            <button id="btnNuevoRepuesto" class="w-full sm:w-auto bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-xl font-bold flex items-center justify-center gap-2 shadow-lg shadow-orange-600/30 transition-all whitespace-nowrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Nuevo Repuesto
            </button>
          </div>
        </div>

        <div class="flex flex-col gap-3 mt-3">
          {referencias?.length ? (
            referencias.map((ref) => (
              <div
                class="inventory-card bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex gap-4 items-center cursor-pointer"
                data-id={ref.id}
                data-modelo={ref.modelo}
                data-familia-id={ref.familias?.id}
                data-family={ref.familias?.nombre?.toUpperCase()}
                data-venta={ref.precio_venta}
                data-costo={ref.precio_costo}
                data-stock={ref.stock_actual}
                data-imagen={ref.imagen_especifica}
              >
                <img
                  src={ref.imagen_especifica || 'https://placehold.co/100x100?text=Sin+imagen'}
                  alt={ref.modelo}
                  class="w-16 h-16 rounded-lg object-cover border border-gray-200"
                />

                <div class="flex-1 flex flex-col min-w-0">
                  <span class="text-xs font-black text-gray-400">#{String(ref.id).slice(-6)}</span>
                  <span class="font-bold text-gray-800 leading-tight truncate">{(ref.familias?.nombre || 'SIN FAMILIA').toUpperCase()}</span>
                  <span class="text-xs font-medium text-gray-500 uppercase mb-1 truncate">{ref.modelo}</span>

                  <div class="flex justify-between items-center mt-1 gap-2">
                    <span class="font-black text-blue-600 text-sm">${ref.precio_venta.toLocaleString('es-CO')}</span>
                    <span class={`px-2 py-0.5 rounded-md text-[10px] font-black tracking-wide border whitespace-nowrap ${ref.stock_actual > 5 ? 'bg-green-100 text-green-700 border-green-200' : 'bg-red-100 text-red-700 border-red-200'}`}>
                      {ref.stock_actual} Uds
                    </span>
                  </div>
                </div>

                <button type="button" class="p-2 text-gray-400 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 rounded-lg transition-colors" aria-label="Opciones">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                  </svg>
                </button>
              </div>
            ))
          ) : (
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 text-center text-gray-600">
              No se encontraron productos para mostrar.
            </div>
          )}
        </div>
      </section>
    </main>

    <button
      id="btnOpenAddModal"
      class="hidden md:flex fixed bottom-8 right-8 items-center gap-2 py-3 px-4 rounded-full text-white text-lg neumorphism-button z-50 transition-transform hover:scale-105"
      style="background: #ff6b35; color: white;"
      aria-label="Agregar nuevo producto"
    >
      <span class="text-2xl font-black">+</span>
      <span class="font-semibold">Agregar un nuevo producto</span>
    </button>

    <div id="addModal" class="hidden fixed inset-0 bg-neutral-950/90 z-[100] backdrop-blur-sm flex items-center justify-center p-4">
      <div class="neumorphism w-full max-w-lg p-6 space-y-6 relative border border-white/60">
        <button id="closeAddModal" class="absolute top-4 right-4 neumorphism-button p-2 text-gray-800 hover:text-orange-600">
          <span class="text-xl">❌</span>
        </button>
        <header class="text-center border-b border-gray-300 pb-4">
          <h2 class="text-2xl font-bold text-orange-600 glow-text">Nuevo Repuesto</h2>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start">
          <div class="col-span-1 space-y-3">
            <label class="block text-sm font-semibold text-gray-600 uppercase tracking-wide">Imagen</label>
