---
import '../../styles.css';
import { supabase } from '../../lib/supabase.js';

// 1. Obtenemos todas las ventas (excluyendo cotizaciones)
const { data: ventasData, error: ventasError } = await supabase
  .from('ventas')
  .select('*')
  .neq('estado', 'cotizacion')
  .order('fecha', { ascending: true });

const ventas = ventasData || [];

// 2. Obtenemos todo el inventario para calcular el capital y ganancias
const { data: inventarioData, error: inventarioError } = await supabase
  .from('referencias')
  .select('stock_actual, precio_costo, precio_venta'); // Nombres exactos de tu tabla

const inventario = inventarioData || [];
if (inventarioError) console.error("Error al traer inventario:", inventarioError);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Estadísticas - Premium Racing</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="apple-touch-icon" href="/icono-192.png" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
      body {
        font-family: 'Inter', sans-serif;
        background: #e6e7ee;
        min-height: 100vh;
        color: #2d3748;
        overflow-x: hidden;
      }
      .page-bg {
        position: fixed; inset: 0; z-index: -10;
        background: radial-gradient(circle at top, rgba(255, 107, 53, 0.18), transparent 55%),
          radial-gradient(circle at 25% 30%, rgba(45, 55, 72, 0.25), transparent 50%),
          linear-gradient(135deg, #e6e7ee 0%, #f6f7fb 100%);
      }
      .neumorphism {
        background: #e6e7ee;
        box-shadow: 10px 10px 20px #bebebe, -10px -10px 20px #ffffff;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.6);
      }
      .layout-height { height: calc(100vh - 5rem); }
      .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
  </head>
  <body>
    <div class="page-bg"></div>

    <header class="w-full h-16 bg-gray-900 shadow-lg border-b-4 border-orange-500 relative z-10 flex items-center shrink-0">
      <div class="w-full max-w-[98%] mx-auto px-4 flex justify-between items-center">
        
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg overflow-hidden shrink-0 border border-gray-700">
            <img src="/logo.png" alt="Premium Racing" class="w-full h-full object-contain p-1" onerror="this.src='https://placehold.co/100x100?text=PR'" />
          </div>
          <div class="hidden lg:block">
            <h1 class="text-xl font-bold text-white tracking-wide leading-tight">Premium Racing</h1>
            <p class="text-orange-400 text-[10px] font-black uppercase tracking-widest">Sistema de Gestión</p>
          </div>
        </div>

        <nav class="flex gap-1 md:gap-2 overflow-x-auto custom-scrollbar pb-1 md:pb-0">
          <a href="/pos/inicio" data-astro-prefetch class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="hidden md:inline">Inicio</span>
          </a>
          <a href="/pos/ventas" class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            <span class="hidden md:inline">Ventas</span>
          </a>
          <a href="/pos/historial" class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="hidden md:inline">Historial</span>
          </a>
          <a href="/pos" class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            <span class="hidden md:inline">Inventario</span>
          </a>
          <a href="/pos/estadisticas" class="nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all text-gray-300 border border-transparent hover:bg-gray-800 hover:text-white whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            <span class="hidden md:inline">Estadísticas</span>
          </a>
        </nav>

        <div class="hidden sm:block ml-2 pl-2 md:ml-4 md:pl-4 border-l border-gray-700 shrink-0">
           <button class="text-gray-400 hover:text-red-400 transition-colors p-2 rounded-lg hover:bg-gray-800" title="Cerrar Sesión">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
               <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
             </svg>
           </button>
        </div>
      </div>
    </header>

    <main class="max-w-[98%] mx-auto py-4 layout-height overflow-y-auto custom-scrollbar flex flex-col gap-6">
      
      <div class="flex items-center justify-between shrink-0">
        <h2 class="text-2xl font-black text-gray-800 tracking-tight">Panel de Rendimiento</h2>
        <span class="text-sm font-bold text-gray-500" id="fechaActual"></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 shrink-0">
        
        <div class="neumorphism p-5 border-l-4 border-green-500">
          <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">Ingresos Totales (Mes)</p>
          <p class="text-3xl font-black text-gray-900" id="kpiIngresos">$0</p>
        </div>

        <div class="neumorphism p-5 border-l-4 border-orange-500">
          <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">Cuentas por Cobrar</p>
          <p class="text-3xl font-black text-gray-900" id="kpiPorCobrar">$0</p>
        </div>

        <div class="neumorphism p-5 border-l-4 border-blue-500">
          <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">Órdenes Completadas</p>
          <p class="text-3xl font-black text-gray-900" id="kpiOrdenes">0</p>
        </div>

        <div class="neumorphism p-5 border-l-4 border-purple-500">
          <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">Ticket Promedio</p>
          <p class="text-3xl font-black text-gray-900" id="kpiTicket">$0</p>
        </div>

        <div class="neumorphism p-5 border-l-4 border-indigo-600 flex flex-col justify-center">
          <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-1">Capital Invertido</p>
          <p class="text-2xl font-black text-indigo-700 mb-2" id="kpiCosto">$0</p>
          
          <div class="flex justify-between items-center border-t border-gray-200 pt-3 mt-1 gap-2">
            <div>
              <p class="text-[9px] font-bold text-gray-400 uppercase">Valor en Venta</p>
              <p class="text-sm font-black text-gray-700" id="kpiVenta">$0</p>
            </div>
            <div class="text-right">
              <p class="text-[9px] font-bold text-gray-400 uppercase">Ganancia Proy.</p>
              <p class="text-sm font-black text-green-600" id="kpiGanancia">$0</p>
            </div>
          </div>
        </div>

      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-1 min-h-[400px]">
        
        <div class="lg:col-span-2 neumorphism p-5 flex flex-col">
          <h3 class="text-sm font-black text-gray-800 uppercase tracking-wider mb-4 border-b border-gray-200 pb-2">Tendencia de Ingresos (Últimos 7 Días)</h3>
          <div class="flex-1 relative w-full h-full min-h-[300px]">
            <canvas id="graficaVentas"></canvas>
          </div>
        </div>

        <div class="neumorphism p-5 flex flex-col">
          <h3 class="text-sm font-black text-gray-800 uppercase tracking-wider mb-4 border-b border-gray-200 pb-2">Repuestos Más Vendidos</h3>
          <div class="flex-1 overflow-y-auto custom-scrollbar pr-2">
            <ul id="listaTopProductos" class="space-y-3 divide-y divide-gray-100">
              </ul>
          </div>
        </div>

      </div>

    </main>

    <script is:inline define:vars={{ ventas, inventario }}>
      window.VENTAS_DB = ventas;
      window.INVENTARIO_DB = inventario;
    </script>

    <script>
      const formatoPesos = (num) => '$' + Math.round(num).toLocaleString('es-CO');
      
      // Mostrar Fecha Actual
      document.getElementById('fechaActual').innerText = new Date().toLocaleDateString('es-CO', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase();

      const ventas = window.VENTAS_DB || [];
      const inventario = window.INVENTARIO_DB || [];

      // 0. CALCULAR VALOR DEL INVENTARIO Y GANANCIAS PROYECTADAS
      let capitalInvertido = 0;
      let valorTotalEnVenta = 0;

      inventario.forEach((item) => {
        const stock = Number(item.stock_actual) || 0;
        
        if (stock > 0) {
          const costoUnitario = Number(item.precio_costo) || 0; 
          const precioVentaPublico = Number(item.precio_venta) || 0;
          
          capitalInvertido += (stock * costoUnitario);
          valorTotalEnVenta += (stock * precioVentaPublico);
        }
      });

      const gananciaProyectada = valorTotalEnVenta - capitalInvertido;

      document.getElementById('kpiCosto').innerText = formatoPesos(capitalInvertido);
      document.getElementById('kpiVenta').innerText = formatoPesos(valorTotalEnVenta);
      document.getElementById('kpiGanancia').innerText = formatoPesos(gananciaProyectada);

      // 1. CALCULAR KPIs GLOBALES DE VENTAS
      let ingresosTotales = 0;
      let porCobrar = 0;
      let ordenesCompletadas = 0;
      
      const ahora = new Date();
      const mesActual = ahora.getMonth();
      const anoActual = ahora.getFullYear();

      ventas.forEach((v) => {
        if (!v.fecha) return;
        const fechaVenta = new Date(v.fecha);
        if (fechaVenta.getMonth() === mesActual && fechaVenta.getFullYear() === anoActual) {
          ingresosTotales += Number(v.monto_recibido) || 0;
        }

        if (v.estado === 'completada') {
          ordenesCompletadas++;
        }

        if (v.estado === 'pendiente') {
          const faltante = (Number(v.total_neto) || 0) - (Number(v.monto_recibido) || 0);
          if (faltante > 0) porCobrar += faltante;
        }
      });

      const ticketPromedio = ordenesCompletadas > 0 ? (ingresosTotales / ordenesCompletadas) : 0;

      document.getElementById('kpiIngresos').innerText = formatoPesos(ingresosTotales);
      document.getElementById('kpiPorCobrar').innerText = formatoPesos(porCobrar);
      document.getElementById('kpiOrdenes').innerText = ordenesCompletadas.toString();
      document.getElementById('kpiTicket').innerText = formatoPesos(ticketPromedio);

      // 2. EXTRAER TOP PRODUCTOS DEL SNAPSHOT
      const conteoProductos = {};

      ventas.forEach((v) => {
        let items = [];
        try {
          items = typeof v.snapshot_carrito === 'string' ? JSON.parse(v.snapshot_carrito) : (v.snapshot_carrito || []);
        } catch(e) {}

        items.forEach((item) => {
          if (!conteoProductos[item.id]) {
            conteoProductos[item.id] = { modelo: item.modelo, familia: item.familia, cantidad: 0, totalGanado: 0 };
          }
          conteoProductos[item.id].cantidad += Number(item.cantidad);
          conteoProductos[item.id].totalGanado += (Number(item.precio) * Number(item.cantidad)) - (item.descuentoTotal || 0);
        });
      });

      const topProductos = Object.values(conteoProductos)
        .sort((a: any, b: any) => b.cantidad - a.cantidad)
        .slice(0, 10); 

      const listaTop = document.getElementById('listaTopProductos');
      if (topProductos.length === 0) {
        listaTop.innerHTML = '<li class="text-sm text-gray-500 font-bold text-center py-4">No hay datos de ventas aún.</li>';
      } else {
        topProductos.forEach((prod: any, index: number) => {
          listaTop.innerHTML += `
            <li class="pt-3 flex items-center justify-between group">
              <div class="flex items-center gap-3">
                <span class="w-6 h-6 rounded bg-gray-200 text-gray-600 font-black text-[10px] flex items-center justify-center shrink-0 group-hover:bg-orange-100 group-hover:text-orange-600 transition-colors">${index + 1}</span>
                <div class="flex flex-col">
                  <span class="text-xs font-black text-gray-800 uppercase leading-tight">${prod.familia}</span>
                  <span class="text-[10px] text-gray-500 font-bold uppercase">Ref: ${prod.modelo}</span>
                </div>
              </div>
              <div class="text-right flex flex-col">
                <span class="text-sm font-black text-orange-600">${prod.cantidad} und</span>
                <span class="text-[10px] font-bold text-gray-400">${formatoPesos(prod.totalGanado)}</span>
              </div>
            </li>
          `;
        });
      }

      // 3. PREPARAR DATOS PARA LA GRÁFICA (Matemática estricta)
      const diasGrafica = 7;
      const fechasLabels = []; 
      const rangosDias = []; 
      const datosVentas = [];
      
      for (let i = diasGrafica - 1; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        
        fechasLabels.push(d.toLocaleDateString('es-CO', { day: '2-digit', month: 'short' }));
        
        const inicioDia = new Date(d);
        inicioDia.setHours(0, 0, 0, 0);
        
        const finDia = new Date(d);
        finDia.setHours(23, 59, 59, 999);
        
        rangosDias.push({ inicio: inicioDia.getTime(), fin: finDia.getTime() });
        datosVentas.push(0);
      }

      ventas.forEach((v) => {
        if (!v.fecha) return;
        const tiempoVenta = new Date(v.fecha).getTime();
        const index = rangosDias.findIndex(rango => tiempoVenta >= rango.inicio && tiempoVenta <= rango.fin);
        
        if (index !== -1) {
          datosVentas[index] += Number(v.monto_recibido) || 0;
        }
      });

      // 4. RENDERIZAR GRÁFICA CON CHART.JS (Auto-Reparable)
      const inicializarChart = () => {
        const canvas = document.getElementById('graficaVentas');
        if (!canvas) return;

        try {
          new window.Chart(canvas, {
            type: 'line',
            data: {
              labels: fechasLabels,
              datasets: [{
                label: 'Ingresos Diarios',
                data: datosVentas,
                borderColor: '#f97316', 
                backgroundColor: 'rgba(249, 115, 22, 0.1)',
                borderWidth: 3,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#f97316',
                pointBorderWidth: 2,
                pointRadius: 4,
                fill: true,
                tension: 0.4 
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: {
                    label: function(context) { return formatoPesos(context.raw); }
                  }
                }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  grid: { color: 'rgba(0,0,0,0.05)' },
                  ticks: {
                    callback: function(value) { return '$' + (Number(value) / 1000) + 'k'; }
                  }
                },
                x: {
                  grid: { display: false }
                }
              }
            }
          });
        } catch (error) {
          console.error("Error al renderizar Chart.js:", error);
          canvas.parentElement.innerHTML = `<div class="flex h-full items-center justify-center text-red-500 font-bold text-sm text-center">No se pudo cargar la gráfica.<br>Revisa tu conexión o desactiva tu bloqueador de anuncios.</div>`;
        }
      };

      if (typeof window.Chart === 'undefined') {
        const scriptLibreria = document.createElement('script');
        scriptLibreria.src = 'https://cdn.jsdelivr.net/npm/chart.js';
        scriptLibreria.onload = inicializarChart;
        document.head.appendChild(scriptLibreria);
      } else {
        inicializarChart();
      }

      (function() {
        const currentPath = window.location.pathname.replace(/\/$/, ""); 
        const navLinks = document.querySelectorAll('.nav-link');
        
        navLinks.forEach(link => {
          const href = link.getAttribute('href')?.replace(/\/$/, ""); 
          const isMatch = (href === '/pos') ? (currentPath === '/pos') : (href && currentPath.includes(href));

          if (isMatch) {
            link.classList.remove('text-gray-300', 'border-transparent', 'hover:bg-gray-800', 'hover:text-white');
            link.classList.add('bg-gray-800', 'text-orange-400', 'border-gray-700', 'shadow-inner');
          }
        });
      })();
    </script>
  </body>
</html>