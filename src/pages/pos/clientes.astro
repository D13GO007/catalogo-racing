    <!-- ───── SCRIPT ───── -->
    <script>
      import { supabase } from '../../lib/supabase.js';

      // ── Referencias DOM ───────────────────────────────────────────────────
      const inputBuscar    = document.getElementById('inputBuscar')    as HTMLInputElement;
      const filtroCiudad   = document.getElementById('filtroCiudad')   as HTMLSelectElement;
      const btnLimpiar     = document.getElementById('btnLimpiarFiltros');
      const contador       = document.getElementById('contadorResultados');
      const btnNuevo       = document.getElementById('btnNuevoCliente');
      const modal          = document.getElementById('modalCliente');
      const modalBox       = document.getElementById('modalClienteBox');
      const modalEliminar  = document.getElementById('modalEliminar');
      const modalElimBox   = document.getElementById('modalEliminarBox');
      const btnCerrar      = document.getElementById('btnCerrarModal');
      const btnCancelar    = document.getElementById('btnCancelarModal');
      const btnGuardar     = document.getElementById('btnGuardarCliente');
      const btnCancelElim  = document.getElementById('btnCancelarEliminar');
      const btnConfElim    = document.getElementById('btnConfirmarEliminar');
      const nombreElimEl   = document.getElementById('nombreEliminar');
      const tituloModal    = document.getElementById('tituloModal');
      const subtituloModal = document.getElementById('subtituloModal');
      const iconModal      = document.getElementById('iconModalCliente');

      let idEliminar: string | null = null;
      let filtroDesc = 'todos';

      // ── Filtros ───────────────────────────────────────────────────────────
      const filas = () => Array.from(document.querySelectorAll<HTMLElement>('.cliente-row'));

      const aplicarFiltros = () => {
        const texto  = inputBuscar.value.toLowerCase().trim();
        const ciudad = filtroCiudad.value.toLowerCase();
        let visibles = 0;

        filas().forEach(fila => {
          const nombre   = fila.dataset.nombre   || '';
          const telefono = fila.dataset.telefono || '';
          const ciudadF  = fila.dataset.ciudad   || '';
          const descuento = Number(fila.dataset.descuento || 0);

          const matchTexto  = !texto  || nombre.includes(texto) || telefono.includes(texto) || ciudadF.includes(texto);
          const matchCiudad = !ciudad || ciudadF === ciudad;
          const matchDesc   = filtroDesc === 'todos'
            || (filtroDesc === 'con'  && descuento > 0)
            || (filtroDesc === 'sin'  && descuento === 0);

          const mostrar = matchTexto && matchCiudad && matchDesc;
          fila.style.display = mostrar ? '' : 'none';
          if (mostrar) visibles++;
        });

        if (contador) {
          contador.textContent = `${visibles} cliente${visibles !== 1 ? 's' : ''} encontrado${visibles !== 1 ? 's' : ''}`;
        }
      };

      inputBuscar.addEventListener('input', aplicarFiltros);
      filtroCiudad.addEventListener('change', aplicarFiltros);

      document.querySelectorAll<HTMLButtonElement>('[data-filtro-desc]').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('[data-filtro-desc]').forEach(b => {
            b.classList.remove('active');
            b.classList.add('text-gray-500');
          });
          btn.classList.add('active');
          btn.classList.remove('text-gray-500');
          filtroDesc = btn.dataset.filtroDesc || 'todos';
          aplicarFiltros();
        });
      });

      btnLimpiar?.addEventListener('click', () => {
        inputBuscar.value = '';
        filtroCiudad.value = '';
        filtroDesc = 'todos';
        document.querySelectorAll('[data-filtro-desc]').forEach((b, i) => {
          b.classList.toggle('active', i === 0);
          (b as HTMLElement).classList.toggle('text-gray-500', i !== 0);
        });
        aplicarFiltros();
      });

      // ── Modales ───────────────────────────────────────────────────────────
      const abrirModal = () => {
        modal?.classList.remove('hidden');
        requestAnimationFrame(() => {
          modal?.classList.remove('opacity-0');
          modalBox?.classList.remove('scale-95');
        });
      };

      const cerrarModal = () => {
        modal?.classList.add('opacity-0');
        modalBox?.classList.add('scale-95');
        setTimeout(() => {
          modal?.classList.add('hidden');
          limpiarFormulario();
        }, 200);
      };

      const abrirModalElim = () => {
        modalEliminar?.classList.remove('hidden');
        requestAnimationFrame(() => {
          modalEliminar?.classList.remove('opacity-0');
          modalElimBox?.classList.remove('scale-95');
        });
      };

      const cerrarModalElim = () => {
        modalEliminar?.classList.add('opacity-0');
        modalElimBox?.classList.add('scale-95');
        setTimeout(() => {
          modalEliminar?.classList.add('hidden');
          idEliminar = null;
        }, 200);
      };

      modal?.addEventListener('click', e => { if (e.target === modal) cerrarModal(); });
      modalEliminar?.addEventListener('click', e => { if (e.target === modalEliminar) cerrarModalElim(); });
      btnCerrar?.addEventListener('click', cerrarModal);
      btnCancelar?.addEventListener('click', cerrarModal);
      btnCancelElim?.addEventListener('click', cerrarModalElim);

      // ── Formulario ────────────────────────────────────────────────────────
      const campo = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLSelectElement;

      const limpiarFormulario = () => {
        ['cliId','cliNombre','cliTelefono','cliCorreo','cliDocumento',
         'cliCiudad','cliDireccion','cliCumpleanos'].forEach(id => {
          (campo(id) as HTMLInputElement).value = '';
        });
        (campo('cliTipoDoc') as HTMLSelectElement).value = 'CC';
        (campo('cliDescuento') as HTMLInputElement).value = '';
      };

      const setModoNuevo = () => {
        if (tituloModal) tituloModal.textContent = 'Nuevo Cliente';
        if (subtituloModal) subtituloModal.textContent = 'Completa la información del cliente';
        if (iconModal) iconModal.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />';
        const btnG = document.getElementById('btnGuardarCliente');
        if (btnG) btnG.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Guardar Cliente';
      };

      const setModoEditar = () => {
        if (tituloModal) tituloModal.textContent = 'Editar Cliente';
        if (subtituloModal) subtituloModal.textContent = 'Modifica la información del cliente';
        if (iconModal) iconModal.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />';
        const btnG = document.getElementById('btnGuardarCliente');
        if (btnG) btnG.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Actualizar Cliente';
      };

      // ── Nuevo cliente ─────────────────────────────────────────────────────
      btnNuevo?.addEventListener('click', () => {
        limpiarFormulario();
        setModoNuevo();
        abrirModal();
      });

      // ── Editar ────────────────────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.btn-editar').forEach(btn => {
        btn.addEventListener('click', e => {
          const b = e.currentTarget as HTMLButtonElement;
          limpiarFormulario();
          setModoEditar();

          (campo('cliId')         as HTMLInputElement).value = b.dataset.id        || '';
          (campo('cliNombre')     as HTMLInputElement).value = b.dataset.nombre     || '';
          (campo('cliTelefono')   as HTMLInputElement).value = b.dataset.telefono   || '';
          (campo('cliCorreo')     as HTMLInputElement).value = b.dataset.correo     || '';
          (campo('cliTipoDoc')    as HTMLSelectElement).value= b.dataset.tipoDoc    || 'CC';
          (campo('cliDocumento')  as HTMLInputElement).value = b.dataset.documento  || '';
          (campo('cliCiudad')     as HTMLInputElement).value = b.dataset.ciudad     || '';
          (campo('cliDireccion')  as HTMLInputElement).value = b.dataset.direccion  || '';
          (campo('cliCumpleanos') as HTMLInputElement).value = b.dataset.cumpleanos || '';
          (campo('cliDescuento')  as HTMLInputElement).value = b.dataset.descuento && b.dataset.descuento !== '0' ? b.dataset.descuento : '';

          abrirModal();
        });
      });

      // ── Eliminar ──────────────────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.btn-eliminar').forEach(btn => {
        btn.addEventListener('click', e => {
          const b = e.currentTarget as HTMLButtonElement;
          idEliminar = b.dataset.id || null;
          if (nombreElimEl) nombreElimEl.textContent = b.dataset.nombre || 'este cliente';
          abrirModalElim();
        });
      });

      // ── Guardar (insert o update) ─────────────────────────────────────────
      btnGuardar?.addEventListener('click', async () => {
        const btn = btnGuardar as HTMLButtonElement;
        const htmlOriginal = btn.innerHTML;

        const nombre   = (campo('cliNombre')   as HTMLInputElement).value.trim().toUpperCase();
        const telefono = (campo('cliTelefono') as HTMLInputElement).value.trim();

        if (!nombre) { alert('El nombre del cliente es obligatorio.'); return; }
        if (!telefono) { alert('El teléfono es obligatorio.'); return; }

        btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Guardando...';
        btn.disabled = true;

        const payload = {
          nombre,
          telefono,
          tipo_documento: (campo('cliTipoDoc')    as HTMLSelectElement).value,
          documento:      (campo('cliDocumento')  as HTMLInputElement).value.trim() || null,
          correo:         (campo('cliCorreo')     as HTMLInputElement).value.trim() || null,
          ciudad:         (campo('cliCiudad')     as HTMLInputElement).value.trim() || null,
          cumpleanos:     (campo('cliCumpleanos') as HTMLInputElement).value || null,
          direccion:      (campo('cliDireccion')  as HTMLInputElement).value.trim() || null,
          descuento_general: parseFloat((campo('cliDescuento') as HTMLInputElement).value) || 0,
        };

        try {
          const id = (campo('cliId') as HTMLInputElement).value;
          let error: any = null;

          if (id) {
            ({ error } = await supabase.from('clientes').update(payload).eq('id', id));
          } else {
            ({ error } = await supabase.from('clientes').insert([payload]));
          }

          if (error) throw error;
          cerrarModal();
          window.location.reload();
        } catch (err: any) {
          alert('Error al guardar: ' + err.message);
          btn.innerHTML = htmlOriginal;
          btn.disabled = false;
        }
      });

      // ── Confirmar eliminar ────────────────────────────────────────────────
      btnConfElim?.addEventListener('click', async () => {
        if (!idEliminar) return;
        const btn = btnConfElim as HTMLButtonElement;
        const htmlOriginal = btn.innerHTML;
        btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Eliminando...';
        btn.disabled = true;

        try {
          const { error } = await supabase.from('clientes').delete().eq('id', idEliminar);
          if (error) throw error;
          cerrarModalElim();
          window.location.reload();
        } catch (err: any) {
          alert('Error al eliminar: ' + err.message);
          btn.innerHTML = htmlOriginal;
          btn.disabled = false;
        }
      });
    </script>
  </body>
</html>
