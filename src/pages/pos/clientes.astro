---
import '../../styles.css';
import { supabase } from '../../lib/supabase.js';

const role    = Astro.cookies.get('pr_session')?.value || 'empleado';
const isAdmin = role === 'admin';

const { data: clientesRaw } = await supabase
  .from('clientes')
  .select('*')
  .order('nombre');

const clientes = clientesRaw || [];
const ciudades = [...new Set(clientes.map((c: any) => c.ciudad).filter(Boolean))].sort() as string[];
const totalClientes  = clientes.length;
const conDescuento   = clientes.filter((c: any) => Number(c.descuento_general) > 0).length;
const totalCiudades  = ciudades.length;

const formatoPesos = (n: number) => '$' + Math.round(n).toLocaleString('es-CO');

const colorInicial = (nombre: string) => {
  const colores = [
    'bg-orange-500', 'bg-blue-500', 'bg-green-500',
    'bg-purple-500', 'bg-rose-500', 'bg-teal-500',
  ];
  const idx = (nombre?.charCodeAt(0) || 0) % colores.length;
  return colores[idx];
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Clientes - Premium Racing</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="apple-touch-icon" href="/icono-192.png" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
      body { font-family: 'Inter', sans-serif; background: #e6e7ee; min-height: 100vh; color: #2d3748; }
      .page-bg {
        position: fixed; inset: 0; z-index: -10;
        background: radial-gradient(circle at top, rgba(255,107,53,.18), transparent 55%),
          linear-gradient(135deg, #e6e7ee 0%, #f6f7fb 100%);
      }
      .neumorphism {
        background: #e6e7ee;
        box-shadow: 10px 10px 20px #bebebe, -10px -10px 20px #ffffff;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,.6);
      }
      .neumorphism-sm {
        background: #e6e7ee;
        box-shadow: 6px 6px 12px #bebebe, -6px -6px 12px #ffffff;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,.6);
      }
      .neumorphism-inset {
        background: #e6e7ee;
        box-shadow: inset 4px 4px 8px #bebebe, inset -4px -4px 8px #ffffff;
        border-radius: 12px;
      }
      .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
      .filter-btn { transition: all .2s ease; }
      .filter-btn.active {
        background: #ea580c;
        color: white;
        box-shadow: 0 4px 12px rgba(234,88,12,.35);
      }
      .row-cliente { transition: background .15s ease; }
      .row-cliente:hover { background: rgba(234,88,12,.04); }
      .tag-descuento {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: white;
        font-size: 10px;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 999px;
        letter-spacing: .04em;
      }
      .badge-estado {
        font-size: 10px; font-weight: 700;
        padding: 3px 10px; border-radius: 999px;
        border: 1px solid; letter-spacing: .05em;
      }
      input[type=search]::-webkit-search-cancel-button { display: none; }
    </style>
  </head>

  <body>
    <div class="page-bg"></div>

    <!-- ───── HEADER ───── -->
    <header class="w-full h-16 bg-gray-900 shadow-lg border-b-4 border-orange-500 relative z-10 flex items-center shrink-0">
      <div class="w-full max-w-[98%] mx-auto px-4 flex justify-between items-center">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg overflow-hidden shrink-0 border border-gray-700">
            <img src="/logo.png" alt="Premium Racing" class="w-full h-full object-contain p-1" onerror="this.src='https://placehold.co/100x100?text=PR'" />
          </div>
          <div class="hidden lg:block">
            <h1 class="text-xl font-bold text-white tracking-wide leading-tight">Premium Racing</h1>
            <p class="text-orange-400 text-[10px] font-black uppercase tracking-widest">Sistema de Gestión</p>
          </div>
        </div>

        <nav class="flex gap-1 md:gap-2 overflow-x-auto custom-scrollbar pb-1 md:pb-0">
          {[
            { href: '/pos/inicio', label: 'Inicio', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
            { href: '/pos/ventas', label: 'Ventas', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z' },
            { href: '/pos/historial', label: 'Historial', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { href: '/pos', label: 'Inventario', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
            { href: '/pos/estadisticas', label: 'Estadísticas', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { href: '/pos/clientes', label: 'Clientes', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
          ].filter(({ href }) => href !== '/pos/estadisticas' || isAdmin).map(({ href, label, icon }) => (
            <a href={href} class={`nav-link px-3 md:px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-all whitespace-nowrap border ${href === '/pos/clientes' ? 'bg-gray-800 text-orange-400 border-gray-700' : 'text-gray-300 border-transparent hover:bg-gray-800 hover:text-white'}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
              <span class="hidden md:inline">{label}</span>
            </a>
          ))}
        </nav>

        <div class="hidden sm:block ml-2 pl-2 border-l border-gray-700 shrink-0">
          <a href="/pos/logout" class="text-gray-400 hover:text-red-400 transition-colors p-2 rounded-lg hover:bg-gray-800 flex items-center" title="Cerrar Sesión">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
        </div>
      </div>
    </header>

    <!-- ───── MAIN ───── -->
    <main class="w-full max-w-[98%] mx-auto py-6 px-2 flex flex-col gap-6 min-h-[calc(100vh-4rem)]">

      <!-- Título + Stats -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <h2 class="text-2xl font-black text-gray-800 tracking-tight flex items-center gap-3">
            <span class="w-9 h-9 rounded-xl bg-orange-500 flex items-center justify-center shadow-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </span>
            Gestión de Clientes
          </h2>
          <p class="text-gray-500 text-sm font-medium mt-1 ml-12">Base de datos de clientes registrados en el sistema</p>
        </div>

        <div class="flex gap-3 flex-wrap">
          <div class="neumorphism-sm px-4 py-3 flex items-center gap-3 min-w-[120px]">
            <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Total</p>
              <p class="text-xl font-black text-gray-900 leading-tight">{totalClientes}</p>
            </div>
          </div>
          <div class="neumorphism-sm px-4 py-3 flex items-center gap-3 min-w-[120px]">
            <div class="w-8 h-8 rounded-lg bg-orange-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Con Descuento</p>
              <p class="text-xl font-black text-gray-900 leading-tight">{conDescuento}</p>
            </div>
          </div>
          <div class="neumorphism-sm px-4 py-3 flex items-center gap-3 min-w-[120px]">
            <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Ciudades</p>
              <p class="text-xl font-black text-gray-900 leading-tight">{totalCiudades}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="neumorphism p-4 flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
        <!-- Búsqueda -->
        <div class="relative flex-1 min-w-0">
          <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none text-orange-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input id="inputBuscar" type="search" placeholder="Buscar por nombre, teléfono, ciudad..."
            class="w-full bg-white border border-gray-200 rounded-xl pl-9 pr-4 py-2.5 text-sm font-medium text-gray-700 placeholder-gray-400 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 transition-all" />
        </div>

        <!-- Filtro ciudad -->
        <div class="relative">
          <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </span>
          <select id="filtroCiudad" class="bg-white border border-gray-200 rounded-xl pl-9 pr-8 py-2.5 text-sm font-medium text-gray-700 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-100 transition-all appearance-none cursor-pointer min-w-[160px]">
            <option value="">Todas las ciudades</option>
            {ciudades.map(c => <option value={c}>{c}</option>)}
          </select>
          <span class="absolute inset-y-0 right-3 flex items-center pointer-events-none text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </div>

        <!-- Filtro descuento -->
        <div class="flex bg-white border border-gray-200 rounded-xl overflow-hidden divide-x divide-gray-200">
          <button data-filtro-desc="todos" class="filter-btn active px-3 py-2 text-xs font-bold transition-colors">Todos</button>
          <button data-filtro-desc="con" class="filter-btn px-3 py-2 text-xs font-bold text-gray-500 hover:bg-gray-50 transition-colors">Con descuento</button>
          <button data-filtro-desc="sin" class="filter-btn px-3 py-2 text-xs font-bold text-gray-500 hover:bg-gray-50 transition-colors">Sin descuento</button>
        </div>

        <!-- Botón nuevo -->
        <button id="btnNuevoCliente"
          class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-xl font-bold text-sm flex items-center gap-2 shadow-lg shadow-orange-600/25 transition-all whitespace-nowrap shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Nuevo Cliente
        </button>
      </div>

      <!-- Tabla -->
      <div class="neumorphism overflow-hidden flex flex-col flex-1">
        <!-- Cabecera tabla -->
        <div class="hidden md:grid grid-cols-[2fr_1.8fr_1.5fr_1fr_auto] gap-4 px-5 py-3 bg-gray-50/80 border-b border-gray-200 text-[10px] font-black text-gray-500 uppercase tracking-widest">
          <span>Cliente</span>
          <span>Contacto</span>
          <span>Ubicación</span>
          <span>Descuento</span>
          <span class="text-right pr-2">Acciones</span>
        </div>

        <!-- Cuerpo tabla -->
        <div id="listaClientes" class="divide-y divide-gray-100 overflow-y-auto custom-scrollbar max-h-[calc(100vh-22rem)]">
          {clientes.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-20 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="font-bold text-base">No hay clientes registrados</p>
              <p class="text-sm mt-1">Haz clic en "Nuevo Cliente" para agregar el primero</p>
            </div>
          ) : clientes.map((cli: any) => (
            <div class="row-cliente cliente-row md:grid md:grid-cols-[2fr_1.8fr_1.5fr_1fr_auto] gap-4 px-5 py-4 flex flex-col"
              data-id={cli.id}
              data-nombre={(cli.nombre || '').toLowerCase()}
              data-telefono={(cli.telefono || '').toLowerCase()}
              data-ciudad={(cli.ciudad || '').toLowerCase()}
              data-descuento={cli.descuento_general || 0}>

              <!-- Columna: Cliente -->
              <div class="flex items-center gap-3 min-w-0">
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center text-white font-black text-base shrink-0 ${colorInicial(cli.nombre || 'A')}`}>
                  {(cli.nombre || '?')[0].toUpperCase()}
                </div>
                <div class="min-w-0">
                  <p class="font-black text-gray-900 text-sm truncate">{cli.nombre}</p>
                  {cli.documento && (
                    <p class="text-[10px] text-gray-400 font-bold uppercase">
                      {cli.tipo_documento || 'DOC'}: {cli.documento}
                    </p>
                  )}
                </div>
              </div>

              <!-- Columna: Contacto -->
              <div class="flex flex-col justify-center gap-0.5 min-w-0">
                <div class="flex items-center gap-1.5 text-gray-700">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-sm font-semibold">{cli.telefono || '—'}</span>
                </div>
                {cli.correo && (
                  <div class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs text-gray-500 truncate max-w-[160px]">{cli.correo}</span>
                  </div>
                )}
              </div>

              <!-- Columna: Ubicación -->
              <div class="flex flex-col justify-center gap-0.5 min-w-0">
                {cli.ciudad && (
                  <div class="flex items-center gap-1.5 text-gray-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="text-sm font-semibold truncate">{cli.ciudad}</span>
                  </div>
                )}
                {cli.direccion && (
                  <div class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    <span class="text-xs text-gray-500 truncate max-w-[140px]">{cli.direccion}</span>
                  </div>
                )}
                {!cli.ciudad && !cli.direccion && <span class="text-xs text-gray-400 italic">Sin ubicación</span>}
              </div>

              <!-- Columna: Descuento -->
              <div class="flex items-center md:justify-start justify-start gap-2">
                {Number(cli.descuento_general) > 0
                  ? <span class="tag-descuento">{cli.descuento_general}% OFF</span>
                  : <span class="text-xs text-gray-400 font-medium">Sin descuento</span>
                }
              </div>

              <!-- Columna: Acciones -->
              <div class="flex items-center justify-end gap-2 shrink-0">
                {isAdmin && (
                  <button
                    class="btn-editar p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                    data-id={cli.id}
                    data-nombre={cli.nombre}
                    data-telefono={cli.telefono}
                    data-tipo-doc={cli.tipo_documento}
                    data-documento={cli.documento}
                    data-correo={cli.correo}
                    data-ciudad={cli.ciudad}
                    data-direccion={cli.direccion}
                    data-cumpleanos={cli.cumpleanos}
                    data-descuento={cli.descuento_general}
                    title="Editar cliente">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                )}
                {isAdmin && (
                  <button
                    class="btn-eliminar p-2 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    data-id={cli.id}
                    data-nombre={cli.nombre}
                    title="Eliminar cliente">
