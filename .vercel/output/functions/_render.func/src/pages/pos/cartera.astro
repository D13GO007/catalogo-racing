---
import '../../styles.css';
import { supabase } from '../../lib/supabase.js';

// Consultamos estrictamente las ventas clasificadas como crédito o con estado pendiente
const { data: carteraData, error } = await supabase
  .from('ventas')
  .select('*')
  .or('tipo_venta.eq.credito,estado.eq.pendiente');

let cartera = carteraData || [];

const fechaActual = new Date();
fechaActual.setHours(0, 0, 0, 0); 

// Ordenar: vencidos/próximos arriba, sin límite abajo
cartera.sort((a, b) => {
  if (!a.fecha_vencimiento) return 1;  
  if (!b.fecha_vencimiento) return -1; 
  return new Date(a.fecha_vencimiento).getTime() - new Date(b.fecha_vencimiento).getTime();
});

const formatoPesos = (num: number) => '$' + Math.round(num).toLocaleString('es-CO');

const formatearFecha = (isoString: string | null) => {
  if (!isoString) return 'Sin límite';
  return new Date(isoString + 'T00:00:00').toLocaleDateString('es-CO', { 
    day: '2-digit', month: 'short', year: 'numeric' 
  });
};

const carteraRender = cartera.map((orden: any) => {
  const idCorto = orden.id ? String(orden.id).split('-').pop()?.substring(6).toUpperCase() : 'N/A';

  // 1. Cálculo real del saldo
  const dineroAbonado = Number(orden.abono ?? orden.monto_recibido ?? 0);
  const saldoPendiente = orden.total_neto - dineroAbonado;

  // 2. Clasificación visual del estado
  let textoEstado = orden.tipo_venta === 'credito' ? 'A CRÉDITO' : 'PENDIENTE';
  let badgeEstado = orden.tipo_venta === 'credito'
    ? 'bg-blue-100 text-blue-700 border-blue-200'
    : 'bg-teal-100 text-teal-700 border-teal-200';

  // 3. Lógica de días y semáforo
  let diasRestantes = null;
  let badgeTiempo = 'bg-gray-100 text-gray-700 border-gray-200';
  let textoTiempo = 'Sin límite';

  if (orden.fecha_vencimiento) {
    const fechaVence = new Date(orden.fecha_vencimiento + 'T00:00:00');
    const diferenciaMs = fechaVence.getTime() - fechaActual.getTime();
    diasRestantes = Math.ceil(diferenciaMs / (1000 * 60 * 60 * 24));

    if (diasRestantes < 0) {
      textoTiempo = `Vencido hace ${Math.abs(diasRestantes)} días`;
      badgeTiempo = 'bg-red-100 text-red-800 border-red-300 font-bold';
    } else if (diasRestantes === 0) {
      textoTiempo = 'Vence HOY';
      badgeTiempo = 'bg-orange-100 text-orange-800 border-orange-300 font-bold animate-pulse';
    } else if (diasRestantes <= 3) {
      textoTiempo = `Faltan ${diasRestantes} días`;
      badgeTiempo = 'bg-yellow-100 text-yellow-800 border-yellow-300';
    } else {
      textoTiempo = `Faltan ${diasRestantes} días`;
      badgeTiempo = 'bg-green-100 text-green-700 border-green-200';
    }
  }

  return {
    ...orden,
    idCorto,
    saldoPendiente,
    textoEstado,
    badgeEstado,
    textoTiempo,
    badgeTiempo,
  };
});
