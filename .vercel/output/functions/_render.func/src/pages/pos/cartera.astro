            <p class="text-sm text-gray-600">Define el monto y el manejo del vencimiento.</p>
          </div>
          <button id="closeAbono" class="text-gray-500 hover:text-red-500 transition-colors p-1 rounded-lg hover:bg-white/60">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>

        <div class="space-y-4">
          <div class="bg-orange-50 border border-orange-200 rounded-xl p-3">
            <p class="text-[10px] font-black text-orange-600 uppercase tracking-wider">Saldo pendiente actual</p>
            <p id="abonoSaldoActual" class="text-xl font-black text-orange-700 mt-1">$0</p>
          </div>

          <div>
            <label class="block text-[11px] font-black text-gray-500 uppercase tracking-wider mb-1">Monto a abonar</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
              <input id="inputMontoAbono" type="number" min="1" step="1" class="w-full rounded-xl border border-gray-300 bg-white px-8 py-3 font-bold text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0" />
            </div>
          </div>

          <div class="rounded-xl border border-gray-300 bg-white/70 p-3 space-y-2">
            <p class="text-[11px] font-black text-gray-500 uppercase tracking-wider">Fecha de vencimiento</p>
            <label class="flex items-center gap-2 text-sm font-semibold text-gray-700">
              <input type="radio" name="opcionVencimiento" value="mantener" checked />
              Mantener la fecha actual
            </label>
            <label class="flex items-center gap-2 text-sm font-semibold text-gray-700">
              <input type="radio" name="opcionVencimiento" value="extender" />
              Dar más días de plazo
            </label>
            <div id="seccionNuevaFecha" class="hidden pt-2">
              <label class="block text-[11px] font-black text-gray-500 uppercase tracking-wider mb-1">Nueva fecha de vencimiento</label>
              <input id="inputNuevaFecha" type="date" class="w-full rounded-xl border border-gray-300 bg-white px-3 py-2.5 font-semibold text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>

          <div class="flex gap-3 justify-end pt-1">
            <button id="btnCancelarAbono" class="px-4 py-2.5 rounded-xl bg-white border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">Cancelar</button>
            <button id="btnConfirmarAbono" class="px-4 py-2.5 rounded-xl bg-blue-600 text-white font-black hover:bg-blue-700 transition-colors">Aplicar Abono</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      import { generarFacturaPDF } from '../../pos/ventas/pdf.ts';
      import { supabase } from '../../lib/supabase.js';

      const formatoPesos = (num: number) => '$' + Math.round(num || 0).toLocaleString('es-CO');
      const consultarHistorialAbonos = async (ventaId: string, abonoFallback?: { monto: number; fecha: string; metodoPago?: string | null }) => {
        let data: any[] | null = null;
        let error: any = null;

        ({ data, error } = await supabase
          .from('historial_abonos')
          .select('monto, fecha, metodo_pago')
          .eq('venta_id', ventaId)
          .order('fecha', { ascending: true }));

        // Compatibilidad con esquemas que no tienen la columna metodo_pago.
        if (error && String(error.message || '').toLowerCase().includes('metodo')) {
          ({ data, error } = await supabase
            .from('historial_abonos')
            .select('monto, fecha')
            .eq('venta_id', ventaId)
            .order('fecha', { ascending: true }));
        }

        if (error) {
          console.warn('No fue posible consultar el historial de abonos:', error);
          return abonoFallback ? [abonoFallback] : [];
        }

        const historial = (data || []).map((abonoItem: any) => ({
          monto: Number(abonoItem.monto || 0),
          fecha: abonoItem.fecha,
          metodoPago: abonoItem.metodo_pago || abonoFallback?.metodoPago || null,
        }));

        return historial.length > 0 ? historial : (abonoFallback ? [abonoFallback] : []);
      };
      const construirSnapshotVenta = (venta: any, overrides: any = {}) => {
        const cliente = venta.cliente_nombre || 'CLIENTE MOSTRADOR';
        const telefono = venta.cliente_telefono && venta.cliente_telefono !== 'N/A'
          ? venta.cliente_telefono
          : '';
        const fechaStr = new Date(venta.fecha).toLocaleDateString('es-CO') + ' ' + new Date(venta.fecha).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true });
        const recibido = Number(overrides.abono ?? overrides.monto_recibido ?? venta.abono ?? venta.monto_recibido ?? 0);
        const totalNeto = Number(overrides.total_neto ?? (venta.total_neto || 0));

        const itemsRaw = typeof venta.snapshot_carrito === 'string'
          ? JSON.parse(venta.snapshot_carrito || '[]')
          : (venta.snapshot_carrito || venta.items || []);

        const itemsNormalizados = (itemsRaw || []).map((item: any) => ({
          cantidad: Number(item.cantidad || 1),
          precio: Number(item.precio || item.precio_venta || 0),
          descuentoTotal: Number(item.descuentoTotal || 0),
          familia: item.familia || 'REPUESTOS',
          modelo: item.modelo || item.descripcion || 'GENÉRICO',
        }));

        return {
          cliente,
          telefono,
          fecha: fechaStr,
          items: itemsNormalizados,
          subtotal: Number(venta.subtotal || 0),
          descuentoGlobal: Number(venta.descuento_global || 0),
          totalNeto,
          recibido,
          tipoVenta: overrides.tipo_venta || venta.tipo_venta || 'credito',
          metodoPago: overrides.metodo_pago || venta.metodo_pago || 'efectivo',
          numeroComprobante: venta.id?.split('-').pop()?.substring(6)?.toUpperCase() || 'N/A',
        };
      };

      const modal = document.getElementById('modalDetalle');
      const modalContainer = document.getElementById('modalDetalleContainer');
      const modalDecision = document.getElementById('modalDecision');
      const modalDecisionBox = document.getElementById('modalDecisionBox');
      const modalAbono = document.getElementById('modalAbono');
      const modalAbonoBox = document.getElementById('modalAbonoBox');
      const inputBuscarCartera = document.getElementById('inputBuscarCartera');
      const modalReporte = document.getElementById('modalReporteCartera');
      const selectTipoReporte = document.getElementById('selectTipoReporte');
      const divParametro = document.getElementById('divParametroReporte');
      const lblParametro = document.getElementById('lblParametroReporte');
      const inputParametro = document.getElementById('inputParametroReporte');
      const btnDescargarReporte = document.getElementById('btnDescargarReporte');
      const decisionTitle = document.getElementById('decisionTitle');
      const decisionMessage = document.getElementById('decisionMessage');
      const decisionCancel = document.getElementById('decisionCancel');
      const decisionOk = document.getElementById('decisionOk');
      let ventaSeleccionada: any = null;
      let snapshotActual: any = null;

      let resolverDecision = null;

      const abrirDecision = () => {
        modalDecision?.classList.remove('hidden');
        requestAnimationFrame(() => {
          modalDecision?.classList.remove('opacity-0');
          modalDecisionBox?.classList.remove('scale-95');
        });
      };

      const cerrarDecision = () => {
        modalDecision?.classList.add('opacity-0');
        modalDecisionBox?.classList.add('scale-95');
        setTimeout(() => modalDecision?.classList.add('hidden'), 180);
      };

      const preguntar = ({ title, message, okText = 'Confirmar', cancelText = 'Cancelar' }) => {
        return new Promise((resolve) => {
          if (!decisionTitle || !decisionMessage || !decisionOk || !decisionCancel) {
            resolve(false);
            return;
          }

          decisionTitle.textContent = title;
          decisionMessage.textContent = message;
          decisionOk.textContent = okText;
          decisionCancel.textContent = cancelText;

          resolverDecision = resolve;
          abrirDecision();
        });
      };

      const notificar = async ({ title, message, okText = 'Entendido' }) => {
        await preguntar({ title, message, okText, cancelText: '' });
      };

      decisionCancel?.addEventListener('click', () => {
        if (resolverDecision) resolverDecision(false);
        resolverDecision = null;
        cerrarDecision();
      });

      decisionOk?.addEventListener('click', () => {
        if (resolverDecision) resolverDecision(true);
        resolverDecision = null;
        cerrarDecision();
      });

      modalDecision?.addEventListener('click', (e) => {
        if (e.target === modalDecision) {
          if (resolverDecision) resolverDecision(false);
          resolverDecision = null;
          cerrarDecision();
        }
      });

      const cerrarModal = () => {
        modal?.classList.add('opacity-0');
        modalContainer?.classList.add('scale-95');
        setTimeout(() => {
          modal?.classList.add('hidden');
          ventaSeleccionada = null;
          snapshotActual = null;
        }, 220);
      };

      const abrirAbono = () => {
        modalAbono?.classList.remove('hidden');
        requestAnimationFrame(() => {
          modalAbono?.classList.remove('opacity-0');
          modalAbonoBox?.classList.remove('scale-95');
        });
      };

      const cerrarAbono = () => {
        modalAbono?.classList.add('opacity-0');
        modalAbonoBox?.classList.add('scale-95');
        setTimeout(() => modalAbono?.classList.add('hidden'), 180);
      };

      const abrirModal = () => {
        modal?.classList.remove('hidden');
        requestAnimationFrame(() => {
          modal?.classList.remove('opacity-0');
          modalContainer?.classList.remove('scale-95');
        });
      };

      // --- LÓGICA DEL BUSCADOR DE CLIENTES EN CARTERA ---
      if (inputBuscarCartera) {
        inputBuscarCartera.addEventListener('input', (e) => {
          const target = e.target;
          if (!(target instanceof HTMLInputElement)) return;

          const termino = target.value.toLowerCase().trim();
          const filasCartera = document.querySelectorAll('.fila-cartera');

          filasCartera.forEach((fila) => {
            const celdaCliente = fila.children[1];
            if (!celdaCliente) return;

            const nombreCliente = (celdaCliente.textContent || '').toLowerCase();
            (fila as HTMLElement).style.display = nombreCliente.includes(termino) ? '' : 'none';
          });
        });
      }

      // --- LÓGICA DEL GENERADOR DE REPORTES PDF ---
      document.getElementById('btnAbrirModalReporte')?.addEventListener('click', () => {
        modalReporte?.classList.remove('hidden');
        modalReporte?.classList.add('flex');
      });

      document.getElementById('btnCerrarModalReporte')?.addEventListener('click', () => {
        modalReporte?.classList.add('hidden');
        modalReporte?.classList.remove('flex');
      });

      modalReporte?.addEventListener('click', (e) => {
        if (e.target === modalReporte) {
          modalReporte.classList.add('hidden');
          modalReporte.classList.remove('flex');
        }
      });

      selectTipoReporte?.addEventListener('change', (e) => {
        const target = e.target;
        if (!(target instanceof HTMLSelectElement)) return;

        if (target.value === 'general') {
          divParametro?.classList.add('hidden');
        } else {
          divParametro?.classList.remove('hidden');
          if (lblParametro) {
            lblParametro.innerText = target.value === 'cliente'
              ? 'Nombre exacto o parcial del Cliente'
              : 'Nombre de la Ciudad';
          }
          if (inputParametro instanceof HTMLInputElement) {
            inputParametro.placeholder = target.value === 'cliente' ? 'Ej. Juan Perez' : 'Ej. Cali';
            inputParametro.value = '';
          }
        }
      });

      btnDescargarReporte?.addEventListener('click', async () => {
        if (!(selectTipoReporte instanceof HTMLSelectElement)) return;

        const tipo = selectTipoReporte.value;
        const parametro = inputParametro instanceof HTMLInputElement
          ? inputParametro.value.trim().toLowerCase()
          : '';

        if (tipo !== 'general' && !parametro) {
          await notificar({
            title: 'Dato requerido',
            message: 'Por favor, ingresa el valor para poder filtrar el reporte.',
          });
          return;
        }

        if (!(btnDescargarReporte instanceof HTMLButtonElement)) return;
        const btnOriginalText = btnDescargarReporte.innerHTML;
        btnDescargarReporte.disabled = true;
        btnDescargarReporte.innerHTML = 'Consultando Base de Datos...';

        try {
          const { data: ventasPendientes, error: errVentas } = await supabase
            .from('ventas')
            .select('*')
            .or('tipo_venta.eq.credito,estado.eq.pendiente');

          const { data: clientesData, error: errClientes } = await supabase
            .from('clientes')
            .select('nombre, ciudad, telefono');

          if (errVentas) throw errVentas;
          if (errClientes) throw errClientes;

          let reporteFiltrado = (ventasPendientes || []).map((venta) => {
            const infoCliente = (clientesData || []).find(
              (c) => c.nombre?.toLowerCase() === venta.cliente_nombre?.toLowerCase()
            ) || {};

            return {
              ...venta,
              ciudad_cliente: infoCliente.ciudad || 'No registrada',
              telefono_cliente: infoCliente.telefono || 'Sin datos',
            };
          });

          if (tipo === 'cliente') {
            reporteFiltrado = reporteFiltrado.filter((v) => v.cliente_nombre?.toLowerCase().includes(parametro));
          } else if (tipo === 'ciudad') {
            reporteFiltrado = reporteFiltrado.filter((v) => v.ciudad_cliente?.toLowerCase().includes(parametro));
          }

          if (reporteFiltrado.length === 0) {
            await notificar({
              title: 'Sin resultados',
              message: 'No se encontraron cuentas pendientes que coincidan con esta búsqueda.',
            });
            return;
          }

          const jsPDFCtor = window.jspdf?.jsPDF;
          if (!jsPDFCtor) {
            throw new Error('jsPDF no está disponible en el navegador.');
          }

          const doc = new jsPDFCtor('landscape');
          doc.setFontSize(22);
          doc.setTextColor(249, 115, 22);
          doc.text('PREMIUM RACING', 14, 20);

          doc.setFontSize(12);
          doc.setTextColor(50);
          doc.text('Reporte Oficial de Cuentas por Cobrar (Cartera Activa)', 14, 28);

          let subFiltro = 'Filtro aplicado: Toda la base de datos (General)';
          if (tipo === 'cliente') subFiltro = `Filtro aplicado: Cliente "${parametro.toUpperCase()}"`;
          if (tipo === 'ciudad') subFiltro = `Filtro aplicado: Ciudad "${parametro.toUpperCase()}"`;

          doc.setFontSize(10);
          doc.setTextColor(100);
          doc.text(subFiltro, 14, 34);
          doc.text(`Fecha de emisión: ${new Date().toLocaleDateString('es-CO')} - ${new Date().toLocaleTimeString('es-CO')}`, 14, 40);

          let sumaTotalCartera = 0;
          const fechaActualPDF = new Date();
          fechaActualPDF.setHours(0, 0, 0, 0);

          const tablaDatos = reporteFiltrado.map((orden) => {
            const idFactura = '#' + (orden.id ? String(orden.id).split('-').pop()?.substring(6).toUpperCase() : 'N/A');
            const saldo = Number(orden.total_neto || 0) - Number(orden.abono || 0);
            sumaTotalCartera += saldo;

            let estadoTiempo = 'Sin límite';
            if (orden.fecha_vencimiento) {
              const fechaVence = new Date(orden.fecha_vencimiento + 'T00:00:00');
              const diffDias = Math.ceil((fechaVence.getTime() - fechaActualPDF.getTime()) / (1000 * 60 * 60 * 24));
              if (diffDias < 0) estadoTiempo = `Vencido (${Math.abs(diffDias)} días)`;
              else if (diffDias === 0) estadoTiempo = 'Vence HOY';
              else estadoTiempo = `En ${diffDias} días`;
            }

            return [
              idFactura,
              orden.cliente_nombre?.toUpperCase() || 'MOSTRADOR',
              String(orden.ciudad_cliente || 'No registrada').toUpperCase(),
              orden.telefono_cliente || 'Sin datos',
              new Date(orden.fecha).toLocaleDateString('es-CO'),
              estadoTiempo,
              '$' + Math.round(saldo).toLocaleString('es-CO'),
            ];
          });

          doc.autoTable({
            startY: 46,
            head: [['Factura', 'Cliente', 'Ciudad', 'Contacto', 'Fecha Compra', 'Estado/Vencimiento', 'Saldo a Pagar']],
            body: tablaDatos,
            theme: 'grid',
            headStyles: { fillColor: [249, 115, 22], textColor: 255, fontStyle: 'bold' },
            alternateRowStyles: { fillColor: [255, 247, 237] },
            styles: { fontSize: 9, cellPadding: 4 },
            columnStyles: {
              6: { halign: 'right', fontStyle: 'bold', textColor: [220, 38, 38] },
            },
          });

          const posicionFinalY = doc.lastAutoTable?.finalY || 50;
          doc.setFontSize(14);
          doc.setTextColor(0);
          doc.text(`Total Cartera Pendiente en este reporte: $${Math.round(sumaTotalCartera).toLocaleString('es-CO')}`, 14, posicionFinalY + 12);

          doc.save(`PremiumRacing_Cartera_${tipo}_${Date.now()}.pdf`);

          modalReporte?.classList.add('hidden');
          modalReporte?.classList.remove('flex');
        } catch (error) {
          console.error(error);
          await notificar({
            title: 'Error al generar',
            message: 'Hubo un error al generar el reporte.',
          });
        } finally {
          btnDescargarReporte.innerHTML = btnOriginalText;
          btnDescargarReporte.disabled = false;
        }
      });

      document.querySelectorAll('.fila-cartera').forEach(fila => {
        fila.addEventListener('click', () => {
          const raw = fila.getAttribute('data-orden');
          if (!raw) return;
          ventaSeleccionada = JSON.parse(raw);

          const abono = Number(ventaSeleccionada.abono ?? ventaSeleccionada.monto_recibido ?? 0);
          const totalNeto = Number(ventaSeleccionada.total_neto || 0);
          const saldo = totalNeto - abono;
          snapshotActual = construirSnapshotVenta(ventaSeleccionada);
          const itemsNormalizados = snapshotActual.items || [];
          const idCorto = snapshotActual.numeroComprobante;
          const cliente = snapshotActual.cliente || 'CLIENTE MOSTRADOR';
          const telefono = snapshotActual.telefono || '';
          const fechaStr = snapshotActual.fecha || '';

          const estadoBadge = document.getElementById('detEstadoBadge');
          if (estadoBadge) {
            estadoBadge.className = 'px-2.5 py-1 rounded-md text-[11px] font-black border tracking-wider uppercase bg-orange-100 text-orange-700 border-orange-200';
            estadoBadge.innerText = ventaSeleccionada.tipo_venta === 'credito' ? 'CRÉDITO' : 'PENDIENTE';
          }

          const tbody = document.getElementById('detItemsTbody');
          if (tbody) {
            tbody.innerHTML = '';
            if (itemsNormalizados.length === 0) {
              tbody.innerHTML = '<tr><td colspan="4" class="py-4 text-center text-gray-400 text-xs">Sin detalle</td></tr>';
            } else {
              itemsNormalizados.forEach((item) => {
                const subtotalLinea = (item.precio * item.cantidad) - item.descuentoTotal;
                tbody.innerHTML += `
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="py-2 px-3 font-bold text-gray-700 align-top">${item.cantidad}</td>
                    <td class="py-2 px-3 align-top">
                      <p class="font-bold text-gray-800 uppercase text-xs leading-tight">${item.familia}</p>
                      <p class="text-[10px] text-gray-500 uppercase mt-0.5">Ref: ${item.modelo}</p>
                    </td>
                    <td class="py-2 px-3 text-right text-gray-600 font-medium align-top">${formatoPesos(item.precio)}</td>
                    <td class="py-2 px-3 text-right font-black text-gray-900 align-top">${formatoPesos(subtotalLinea)}</td>
                  </tr>`;
              });
            }
          }

          const detIdOrden = document.getElementById('detIdOrden');
          const detCliente = document.getElementById('detCliente');
          const detTelefono = document.getElementById('detTelefono');
          const detFecha = document.getElementById('detFecha');
          const detMetodo = document.getElementById('detMetodo');
          const detSubtotal = document.getElementById('detSubtotal');
          const detDescuento = document.getElementById('detDescuento');
          const detTotalNeto = document.getElementById('detTotalNeto');
          const detAbonado = document.getElementById('detAbonado');
          const detSaldo = document.getElementById('detSaldo');

          if (detIdOrden) detIdOrden.innerText = `REF: ${idCorto}`;
          if (detCliente) detCliente.innerText = cliente.toUpperCase();
          if (detTelefono) detTelefono.innerText = `TEL: ${telefono || 'N/A'}`;
          if (detFecha) detFecha.innerText = fechaStr;
          if (detMetodo) detMetodo.innerText = `Pago: ${ventaSeleccionada.metodo_pago || 'efectivo'}`;
          if (detSubtotal) detSubtotal.innerText = formatoPesos(snapshotActual.subtotal);
          if (detDescuento) detDescuento.innerText = `-${formatoPesos(snapshotActual.descuentoGlobal)}`;
          if (detTotalNeto) detTotalNeto.innerText = formatoPesos(totalNeto);
          if (detAbonado) detAbonado.innerText = formatoPesos(abono);
          if (detSaldo) detSaldo.innerText = formatoPesos(saldo);

          document.getElementById('detAbonadoContainer')?.classList.remove('hidden');
          document.getElementById('detSaldoContainer')?.classList.remove('hidden');

          abrirModal();
        });
      });

      document.getElementById('closeDetalle')?.addEventListener('click', () => {
        cerrarModal();
      });

      modal?.addEventListener('click', (e) => {
        if (e.target === modal) cerrarModal();
      });

      const ejecutarConCarga = async (btn, textoCargando, tarea) => {
        const textoOriginal = btn.innerHTML;
        btn.disabled = true;
        btn.classList.add('opacity-70', 'cursor-wait');
        btn.innerHTML = `<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>${textoCargando}`;

        try {
          await tarea();
        } finally {
          btn.innerHTML = textoOriginal;
          btn.disabled = false;
          btn.classList.remove('opacity-70', 'cursor-wait');
        }
      };

      const calcularSaldoPendiente = () => {
        if (!ventaSeleccionada) return 0;
        const total = Number(ventaSeleccionada.total_neto || 0);
        const recibido = Number(ventaSeleccionada.abono ?? ventaSeleccionada.monto_recibido ?? 0);
        return Math.max(0, total - recibido);
      };

      document.getElementById('btnHistorialDescargar')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        if (!(btn instanceof HTMLButtonElement)) return;
        if (!snapshotActual) return;

        await ejecutarConCarga(btn, 'Generando PDF...', async () => {
          const historialAbonos = ventaSeleccionada?.id
            ? await consultarHistorialAbonos(ventaSeleccionada.id)
            : [];
          await generarFacturaPDF(snapshotActual, 'descargar', { historialAbonos });
        });
      });

      document.getElementById('btnHistorialImprimir')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        if (!(btn instanceof HTMLButtonElement)) return;
        if (!snapshotActual) return;

        await ejecutarConCarga(btn, 'Preparando impresión...', async () => {
          const historialAbonos = ventaSeleccionada?.id
            ? await consultarHistorialAbonos(ventaSeleccionada.id)
            : [];
          await generarFacturaPDF(snapshotActual, 'imprimir', { historialAbonos });
        });
      });

      document.getElementById('btnSaldar')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        if (!(btn instanceof HTMLButtonElement)) return;
        if (!ventaSeleccionada?.id) {
          await notificar({
            title: 'Sin selección',
            message: 'No hay una deuda seleccionada para saldar.',
          });
          return;
        }

        const idCorto = ventaSeleccionada.id?.split('-').pop()?.substring(6)?.toUpperCase() || 'N/A';
        const confirmar = await preguntar({
          title: 'Confirmar pago total',
          message: `¿Deseas saldar por completo la deuda #${idCorto}? Esta acción marcará la venta como completada.`,
          okText: 'Sí, saldar',
          cancelText: 'Cancelar',
        });
        if (!confirmar) return;

        try {
          await ejecutarConCarga(btn, 'Procesando...', async () => {
            const totalNeto = Number(ventaSeleccionada.total_neto || 0);
            const payload = {
              estado: 'completada',
              tipo_venta: 'contado',
              monto_recibido: totalNeto,
              abono: totalNeto,
            };

            let { error } = await supabase
              .from('ventas')
              .update(payload)
              .eq('id', ventaSeleccionada.id);

            // Compatibilidad si la tabla no tiene la columna `abono`.
            if (error && String(error.message || '').toLowerCase().includes('abono')) {
              ({ error } = await supabase
                .from('ventas')
                .update({
                  estado: 'completada',
                  tipo_venta: 'contado',
                  monto_recibido: totalNeto,
                })
                .eq('id', ventaSeleccionada.id));
            }

            if (error) throw error;

            await notificar({
              title: 'Pago aplicado',
              message: 'La deuda fue saldada correctamente.',
              okText: 'Continuar',
            });
            window.location.reload();
          });
        } catch (error) {
          console.error('Error al saldar deuda:', error);
          await notificar({
            title: 'Error al saldar',
            message: 'No fue posible actualizar la deuda. Intenta nuevamente.',
          });
        }
      });

      document.getElementById('btnAbonar')?.addEventListener('click', async () => {
        if (!ventaSeleccionada?.id) {
          await notificar({
            title: 'Sin selección',
            message: 'Abre primero una deuda para registrar un abono.',
          });
          return;
        }

        const saldoActual = calcularSaldoPendiente();
        const labelSaldo = document.getElementById('abonoSaldoActual');
        const inputMonto = document.getElementById('inputMontoAbono');
        const inputNuevaFecha = document.getElementById('inputNuevaFecha');
        const seccionNuevaFecha = document.getElementById('seccionNuevaFecha');

        if (labelSaldo) labelSaldo.textContent = formatoPesos(saldoActual);
        if (inputMonto instanceof HTMLInputElement) inputMonto.value = '';
        if (inputNuevaFecha instanceof HTMLInputElement) inputNuevaFecha.value = '';
        if (seccionNuevaFecha) seccionNuevaFecha.classList.add('hidden');

        document.querySelectorAll('input[name="opcionVencimiento"]').forEach((el) => {
          if (el instanceof HTMLInputElement) {
            el.checked = el.value === 'mantener';
          }
        });

        abrirAbono();
      });

      document.querySelectorAll('input[name="opcionVencimiento"]').forEach((el) => {
        el.addEventListener('change', () => {
          const opcion = document.querySelector('input[name="opcionVencimiento"]:checked');
          const seccionNuevaFecha = document.getElementById('seccionNuevaFecha');
          if (!(opcion instanceof HTMLInputElement) || !seccionNuevaFecha) return;

          if (opcion.value === 'extender') seccionNuevaFecha.classList.remove('hidden');
          else seccionNuevaFecha.classList.add('hidden');
        });
      });

      document.getElementById('closeAbono')?.addEventListener('click', () => cerrarAbono());
      document.getElementById('btnCancelarAbono')?.addEventListener('click', () => cerrarAbono());

      modalAbono?.addEventListener('click', (e) => {
        if (e.target === modalAbono) cerrarAbono();
      });

      document.getElementById('btnConfirmarAbono')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        if (!(btn instanceof HTMLButtonElement)) return;
        if (!ventaSeleccionada?.id) return;

        const inputMonto = document.getElementById('inputMontoAbono');
        const inputNuevaFecha = document.getElementById('inputNuevaFecha');
        const opcion = document.querySelector('input[name="opcionVencimiento"]:checked');

        if (!(inputMonto instanceof HTMLInputElement)) return;
        const montoAbono = Number(inputMonto.value || 0);
        const saldoActual = calcularSaldoPendiente();

        if (!montoAbono || montoAbono <= 0) {
          await notificar({ title: 'Monto inválido', message: 'Ingresa un monto mayor a cero.' });
          return;
        }
        if (montoAbono > saldoActual) {
          await notificar({ title: 'Monto excedido', message: 'El abono no puede ser mayor al saldo pendiente.' });
          return;
        }

        const extiende = opcion instanceof HTMLInputElement && opcion.value === 'extender';
        if (extiende) {
          if (!(inputNuevaFecha instanceof HTMLInputElement) || !inputNuevaFecha.value) {
            await notificar({ title: 'Fecha requerida', message: 'Selecciona la nueva fecha de vencimiento.' });
            return;
          }
        }

        try {
          await ejecutarConCarga(btn, 'Aplicando abono...', async () => {
            const totalNeto = Number(ventaSeleccionada.total_neto || 0);
            const recibidoActual = Number(ventaSeleccionada.abono ?? ventaSeleccionada.monto_recibido ?? 0);
            const nuevoRecibido = recibidoActual + montoAbono;
            const quedaSaldo = nuevoRecibido < totalNeto;

            const payload: any = {
              estado: quedaSaldo ? 'pendiente' : 'completada',
              tipo_venta: quedaSaldo ? 'abono' : 'contado',
              monto_recibido: nuevoRecibido,
              abono: nuevoRecibido,
            };

            if (extiende && inputNuevaFecha instanceof HTMLInputElement) {
              payload.fecha_vencimiento = inputNuevaFecha.value;
            }

            let { error } = await supabase
              .from('ventas')
              .update(payload)
              .eq('id', ventaSeleccionada.id);

            if (error && String(error.message || '').toLowerCase().includes('abono')) {
              const payloadCompat: any = {
                estado: payload.estado,
                tipo_venta: payload.tipo_venta,
                monto_recibido: payload.monto_recibido,
              };
              if (extiende && inputNuevaFecha instanceof HTMLInputElement) {
                payloadCompat.fecha_vencimiento = inputNuevaFecha.value;
              }

              ({ error } = await supabase
                .from('ventas')
                .update(payloadCompat)
                .eq('id', ventaSeleccionada.id));
            }

            if (error) throw error;

            const fechaAbono = new Date().toISOString();
            const metodoAbono = ventaSeleccionada?.metodo_pago || 'efectivo';

            let { error: errorInsertAbono } = await supabase
              .from('historial_abonos')
              .insert({
                venta_id: ventaSeleccionada.id,
                monto: montoAbono,
                fecha: fechaAbono,
                metodo_pago: metodoAbono,
              });

            if (errorInsertAbono && String(errorInsertAbono.message || '').toLowerCase().includes('metodo')) {
              ({ error: errorInsertAbono } = await supabase
                .from('historial_abonos')
                .insert({
                  venta_id: ventaSeleccionada.id,
                  monto: montoAbono,
                  fecha: fechaAbono,
                }));
            }

            if (errorInsertAbono) {
              console.warn('No fue posible guardar el abono en historial_abonos:', errorInsertAbono);
            }

            const { data: ventaActualizada, error: errorVenta } = await supabase
              .from('ventas')
              .select('*')
              .eq('id', ventaSeleccionada.id)
              .single();

            if (errorVenta) throw errorVenta;

            ventaSeleccionada = ventaActualizada;
            snapshotActual = construirSnapshotVenta(ventaActualizada);

            cerrarAbono();

            window.location.reload();
          });
        } catch (error) {
          console.error('Error al registrar abono:', error);
          await notificar({
            title: 'Error al abonar',
            message: 'No fue posible registrar el abono. Intenta nuevamente.',
          });
        }
      });
    </script>
  </body>
</html>
