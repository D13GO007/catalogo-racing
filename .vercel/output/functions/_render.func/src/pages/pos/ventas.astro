      const txtTotal          = document.getElementById('txtTotal')               as HTMLElement;
      const btnVaciar         = document.getElementById('btnVaciar')              as HTMLElement;
      const familyButtons     = document.querySelectorAll('.family-btn');
      const clearFilter       = document.getElementById('clearFilter')            as HTMLElement;
      const noResultsMsg      = document.getElementById('noResultsMsg')           as HTMLElement;

      const checkoutModal      = document.getElementById('checkoutModal')         as HTMLElement;
      const checkoutContainer  = document.getElementById('checkoutContainer')     as HTMLElement;
      const inputMontoRecibido = document.getElementById('inputMontoRecibido')    as HTMLInputElement;
