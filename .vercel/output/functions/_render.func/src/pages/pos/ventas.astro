        carrito, initCarrito, renderCarrito,
        agregarProductoAlCarrito, vaciarCarrito, setDescuentoGlobal, inyectarProductosAlCarrito,
      }                                    from '../../pos/ventas/carrito';
      import {
        initCheckout, actualizarCheckout, resetCheckoutUI,
        setTotalBruto, getRecibidoFinal, getDescuentoGlobal,
        tipoVenta, metodoPago, totalBrutoVenta, totalNetoVenta,
      }                                    from '../../pos/ventas/checkout';
      import { renderFactura, initFacturaModal } from '../../pos/ventas/factura';
      import { generarFacturaPDF }         from '../../pos/ventas/pdf';
      import { initClienteModal }          from '../../pos/ventas/clientes';
      import { formatoPesos, limpiarMoneda, obtenerNumeroComprobanteDesdeVentaId } from '../../pos/ventas/utils';
