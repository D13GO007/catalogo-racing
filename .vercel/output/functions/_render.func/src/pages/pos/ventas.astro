---
import '../../styles.css'; 
import { supabase } from '../../lib/supabase.js';

// En POS solo cargamos referencias activas; no dependemos de visibilidad en catalogo.
const { data: referencias, error } = await supabase
  .from('referencias')
  .select(`id, modelo, precio_venta, stock_actual, imagen_especifica, familias ( nombre )`)
  .eq('activo', true)
  .order('modelo');

// Extraemos las familias (categorías) únicas para los filtros
const familias = Array.from(
  new Set((referencias || []).map(r => r.familias?.nombre).filter(Boolean))
).sort((a, b) => a.localeCompare(b));

// Traemos los clientes registrados
const { data: clientesData } = await supabase
  .from('clientes')
  .select('*')
  .order('nombre');
const clientes = clientesData || [];

// Función para limpiar nombres redundantes
function limpiarNombreReferencia(nombreFamilia, nombreReferencia) {
  if (!nombreFamilia || !nombreReferencia) return nombreReferencia;
  // Convertimos a minúsculas para comparar sin errores
  const familiaClean = nombreFamilia.toLowerCase().trim();
  const refClean = nombreReferencia.toLowerCase();

  if (refClean.includes(familiaClean)) {
    // Si la referencia ya trae el nombre de la familia, se lo quitamos y dejamos solo el modelo
    // Usamos expresión regular para ignorar mayúsculas/minúsculas
    const regex = new RegExp(familiaClean, 'i');
    return nombreReferencia.replace(regex, '').trim();
  }
  
  return nombreReferencia;
}
