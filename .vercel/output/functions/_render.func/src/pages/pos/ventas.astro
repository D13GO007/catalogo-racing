      /* Apilar y centrar el encabezado en la tirilla */
      .formato-tirilla #invoiceHeader {
        flex-direction: column !important;
        align-items: center !important;
        text-align: center !important;
        border-bottom: 1px dashed black !important;
        padding-bottom: 10px !important;
      }
      .formato-tirilla #invoiceHeader > div {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100% !important;
        text-align: center !important;
        margin-bottom: 8px;
      }
      .formato-tirilla #invoiceHeader .text-right {
        text-align: center !important;
      }
      
      /* Ajuste de Cliente en Tirilla */
      .formato-tirilla .bg-gray-50 {
        background: transparent !important;
        border: none !important;
        border-bottom: 1px dashed black !important;
        padding: 10px 0 !important;
        text-align: left !important;
      }
      
      /* Ajuste de Totales en Tirilla (Quitar fondo gris y expandir) */
