      const successModal       = document.getElementById('successModal')          as HTMLElement;
      const successContainer   = document.getElementById('successContainer')      as HTMLElement;
      const successClienteName = document.getElementById('successClienteName')    as HTMLElement;
      const successFecha       = document.getElementById('successFecha')          as HTMLElement;
      const successTotal       = document.getElementById('successTotal')          as HTMLElement;
      const btnNuevaVenta      = document.getElementById('btnNuevaVenta')         as HTMLElement;

      const invoiceModal       = document.getElementById('invoiceModal')          as HTMLElement;
      const printSection       = document.getElementById('printSection')          as HTMLElement;
      const btnImprimirReciboSuccess = document.getElementById('btnImprimirReciboSuccess') as HTMLElement;
      const btnDescargarPDF    = document.getElementById('btnDescargarPDF')       as HTMLButtonElement | null;
      const btnPrintInvoice    = document.getElementById('btnPrintInvoice')       as HTMLButtonElement | null;
      const btnCotizar         = document.getElementById('btnCotizar')            as HTMLButtonElement | null;
      const btnGuardar         = document.getElementById('btnGuardar')            as HTMLButtonElement | null;
      const btnVerPendientes   = document.getElementById('btnVerPendientes')      as HTMLButtonElement | null;
      const badgePendientes    = document.getElementById('badgePendientes')       as HTMLElement;
      const modalPendientes    = document.getElementById('modalPendientes')       as HTMLElement;
      const closePendientes    = document.getElementById('closePendientes')       as HTMLButtonElement | null;
      const listaPendientes    = document.getElementById('listaPendientes')       as HTMLElement;
      const actionSuccessModal = document.getElementById('actionSuccessModal')    as HTMLElement;
      const actionTitle        = document.getElementById('actionTitle')           as HTMLElement;
      const actionSubtitle     = document.getElementById('actionSubtitle')        as HTMLElement;
      const actionIcon         = document.getElementById('actionIcon')            as HTMLElement;
      const actionPdfButtons   = document.getElementById('actionPdfButtons')      as HTMLElement;
      const btnActionImprimir  = document.getElementById('btnActionImprimir')     as HTMLButtonElement | null;
      const btnActionDescargar = document.getElementById('btnActionDescargar')    as HTMLButtonElement | null;
      const btnActionNuevaVenta = document.getElementById('btnActionNuevaVenta')  as HTMLButtonElement | null;

      // ── Estado compartido ──────────────────────────────────────────────────
      let ultimaVenta: VentaSnapshot | null = null;
      let ultimaCotizacion: VentaSnapshot | null = null;
      let pedidosGuardados: Array<{
        id: number;
        cliente: string;
        telefono: string;
        hora: string;
        items: typeof carrito;
      }> = [];

      const mostrarToast = (mensaje: string, tipo: 'error' | 'success' | 'info' = 'error') => {
        const container = document.getElementById('toastContainer');
        if (!container) return;

        const toast = document.createElement('div');
        const bgClass = tipo === 'error'
          ? 'bg-red-50 border-red-200 text-red-700'
          : tipo === 'success'
          ? 'bg-green-50 border-green-200 text-green-700'
          : 'bg-blue-50 border-blue-200 text-blue-700';

        const icon = tipo === 'error'
          ? '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          : tipo === 'success'
          ? '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>'
          : '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';

        toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl border shadow-lg font-bold text-sm transform transition-all duration-300 translate-x-full opacity-0 ${bgClass}`;
        toast.innerHTML = `${icon} <span>${mensaje}</span>`;
        container.appendChild(toast);

        requestAnimationFrame(() => {
          toast.classList.remove('translate-x-full', 'opacity-0');
        });

        setTimeout(() => {
          toast.classList.add('translate-x-full', 'opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, 3500);
      };

      const confirmarAccion = (titulo: string, mensaje: string): Promise<boolean> => {
        return new Promise(resolve => {
          const modal = document.getElementById('customConfirmModal') as HTMLElement;
          const box = document.getElementById('confirmBox') as HTMLElement;
          const btnCancel = document.getElementById('btnCancelConfirm') as HTMLButtonElement;
          const btnAccept = document.getElementById('btnAcceptConfirm') as HTMLButtonElement;

          (document.getElementById('confirmTitle') as HTMLElement).innerText = titulo;
          (document.getElementById('confirmMessage') as HTMLElement).innerText = mensaje;

          modal.classList.remove('hidden');
          requestAnimationFrame(() => {
            modal.classList.remove('opacity-0');
            box.classList.remove('scale-95');
          });

          const limpiarYResolver = (resultado: boolean) => {
            modal.classList.add('opacity-0');
            box.classList.add('scale-95');
            setTimeout(() => {
              modal.classList.add('hidden');
              resolve(resultado);
            }, 200);

            btnCancel.removeEventListener('click', onCancel);
            btnAccept.removeEventListener('click', onAccept);
          };

          const onCancel = () => limpiarYResolver(false);
          const onAccept = () => limpiarYResolver(true);

          btnCancel.addEventListener('click', onCancel);
          btnAccept.addEventListener('click', onAccept);
        });
      };

      // ── Inicializar módulos ────────────────────────────────────────────────
      initFiltros({
        buscador,
        tarjetasProducto,
        familyButtons,
        clearFilter,
        noResultsMsg,
      });

      initCarrito({
        contenedor:    carritoContenedor,
        vacioEl:       carritoVacio,
        txtSubtotal,
        txtTotal,
        modalDescuento: document.getElementById('editCartItemModal')        as HTMLElement,
        modName:        document.getElementById('modalCartItemName')        as HTMLElement,
        modOrigPrice:   document.getElementById('modalCartItemOriginalPrice') as HTMLElement,
        modQty:         document.getElementById('modalCartItemQuantity')    as HTMLElement,
        modOrigTotal:   document.getElementById('modalCartItemOriginalTotal') as HTMLElement,
        modDescPerc:    document.getElementById('modalCartItemDescPerc')    as HTMLInputElement,
        modDescVal:     document.getElementById('modalCartItemDescVal')     as HTMLInputElement,
        modNewTotal:    document.getElementById('modalCartItemNewTotal')    as HTMLElement,
      });

      initCheckout({
        checkoutSubtotal:      document.getElementById('checkoutSubtotal')      as HTMLElement,
        globalDescPerc:        document.getElementById('globalDescPerc')        as HTMLInputElement,
        globalDescVal:         document.getElementById('globalDescVal')         as HTMLInputElement,
        checkoutTotalNeto:     document.getElementById('checkoutTotalNeto')     as HTMLElement,
        checkoutTotalRecibido: document.getElementById('checkoutTotalRecibido') as HTMLElement,
        cajaCambio:            document.getElementById('cajaCambio')            as HTMLElement,
        lblCambio:             document.getElementById('lblCambio')             as HTMLElement,
        checkoutCambio:        document.getElementById('checkoutCambio')        as HTMLElement,
        btnConfirmarPago:      document.getElementById('btnConfirmarPago')      as HTMLButtonElement,
        seccionMetodoPago:     document.getElementById('seccionMetodoPago')     as HTMLElement,
        seccionPagoMultiple:   document.getElementById('seccionPagoMultiple')   as HTMLElement,
        contMontoUnico:        document.getElementById('contenedorMontoUnico')  as HTMLElement,
        inputMontoRecibido,
        contMontoMultiple:     document.getElementById('contenedorMontoMultiple') as HTMLElement,
        lblRestanteMulti:      document.getElementById('lblRestanteMulti')      as HTMLElement,
        multiEfectivo:         document.getElementById('multiEfectivo')         as HTMLInputElement,
        multiNequi:            document.getElementById('multiNequi')            as HTMLInputElement,
        multiTarjeta:          document.getElementById('multiTarjeta')          as HTMLInputElement,
        seccionFechaPago:      document.getElementById('seccionFechaPago')      as HTMLElement,
        inputFechaPago:        document.getElementById('inputFechaPago')        as HTMLInputElement,
      });

      initFacturaModal(invoiceModal, printSection);

      initClienteModal(document.getElementById('selectCliente') as HTMLSelectElement);

      const selectClienteGlobalDesc = document.getElementById('selectCliente') as HTMLSelectElement | null;
      const aplicarDescuentoCliente = () => {
        const inputDescuentoPorcentaje = document.getElementById('globalDescPerc') as HTMLInputElement | null;

        if (!selectClienteGlobalDesc || selectClienteGlobalDesc.selectedIndex < 0) {
          setDescuentoGlobal(0);
          if (inputDescuentoPorcentaje) {
            inputDescuentoPorcentaje.value = '';
            inputDescuentoPorcentaje.dispatchEvent(new Event('input'));
          }
          return;
        }

        const selectedOption = selectClienteGlobalDesc.options[selectClienteGlobalDesc.selectedIndex];
        const descuento = parseFloat(selectedOption.getAttribute('data-descuento') || '0') || 0;

        setDescuentoGlobal(descuento);

        if (inputDescuentoPorcentaje) {
          inputDescuentoPorcentaje.value = descuento > 0 ? String(descuento) : '';
          inputDescuentoPorcentaje.dispatchEvent(new Event('input'));
        }
      };

      selectClienteGlobalDesc?.addEventListener('change', aplicarDescuentoCliente);
      aplicarDescuentoCliente();

      // ── Botones de Tipo de Venta (Pagar Todo / Abonar / Pagar Después) ────
      const botonestipoVenta = document.querySelectorAll('.tipo-venta-btn');
      botonestipoVenta.forEach(btn => {
        btn.addEventListener('click', () => {
          const tipoSeleccionado = (btn as HTMLElement).getAttribute('data-tipo') || 'todo';
          
          // Si se selecciona "Abonar", vaciar y dar foco al input de monto
          if (tipoSeleccionado === 'abono') {
            inputMontoRecibido.value = '';
            setTimeout(() => {
              inputMontoRecibido.focus();
            }, 50);
          }
          
          // Si se selecciona "Pagar Todo", prellenar con el total neto
          if (tipoSeleccionado === 'todo') {
            inputMontoRecibido.value = totalNetoVenta.toLocaleString('es-CO');
          }
        });
      });

      // ── Eventos del carrito ────────────────────────────────────────────────
      botonesAgregar.forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          agregarProductoAlCarrito(btn);
        });
      });

      tarjetasProducto.forEach(tarjeta => {
        tarjeta.addEventListener('click', () => {
          agregarProductoAlCarrito(tarjeta.querySelector('.btn-agregar') as HTMLElement);
        });
      });

      btnVaciar.addEventListener('click', async () => {
        if (carrito.length === 0) return;
        const confirmado = await confirmarAccion('¿Vaciar pedido?', 'Se eliminarán todos los repuestos del carrito actual.');
        if (!confirmado) return;
        vaciarCarrito();
        renderCarrito();
        mostrarToast('Pedido vaciado correctamente.', 'info');
      });

      const obtenerClienteActual = () => {
        const clienteSelect = document.getElementById('selectCliente') as HTMLSelectElement;
        const cliente = clienteSelect?.value || 'Cliente Mostrador';
        const telefono = clienteSelect && clienteSelect.selectedIndex > -1
          ? clienteSelect.options[clienteSelect.selectedIndex].getAttribute('data-telefono') || 'N/A'
          : 'N/A';
        return { clienteSelect, cliente, telefono };
      };

      const limpiarVistaVenta = () => {
        const { clienteSelect } = obtenerClienteActual();
        vaciarCarrito();
        if (clienteSelect) clienteSelect.value = 'Cliente Mostrador';
        renderCarrito();
      };

      const actualizarBadgePendientes = () => {
        if (pedidosGuardados.length > 0) {
          badgePendientes.innerText = String(pedidosGuardados.length);
          badgePendientes.classList.remove('hidden');
        } else {
          badgePendientes.classList.add('hidden');
        }
      };

      const cargarFacturaEnEdicion = () => {
        const facturaGuardada = localStorage.getItem('facturaEnEdicion');
        if (!facturaGuardada) return;

        try {
          const factura = JSON.parse(facturaGuardada);

          const banner = document.getElementById('bannerEdicion');
          const textoBanner = document.getElementById('textoBannerEdicion');
          const idCorto = factura?.id?.split('-')?.pop()?.substring(6)?.toUpperCase() || 'N/A';
          if (banner && textoBanner) {
            banner.classList.remove('hidden');
            textoBanner.innerText = `Estás modificando la orden #${idCorto} a nombre de ${factura?.cliente_nombre || 'Cliente Mostrador'}.`;
          }

          const rawItems = Array.isArray(factura?.productos_venta)
            ? factura.productos_venta
            : (typeof factura?.snapshot_carrito === 'string'
              ? JSON.parse(factura.snapshot_carrito || '[]')
              : (factura?.snapshot_carrito || factura?.items || []));

          if (Array.isArray(rawItems) && rawItems.length > 0) {
            inyectarProductosAlCarrito(rawItems);
          }

          const clienteSelect = document.getElementById('selectCliente') as HTMLSelectElement | null;
          if (clienteSelect && factura?.cliente_nombre) {
            const clienteObjetivo = String(factura.cliente_nombre);
            const existe = Array.from(clienteSelect.options).some(opt => opt.value === clienteObjetivo);

            if (!existe) {
              const opt = document.createElement('option');
              opt.value = clienteObjetivo;
              opt.text = clienteObjetivo.toUpperCase();
              opt.setAttribute('data-telefono', String(factura?.cliente_telefono || 'N/A'));
              opt.setAttribute('data-descuento', String(factura?.descuento_global || 0));
              clienteSelect.appendChild(opt);
            }

            clienteSelect.value = clienteObjetivo;
            clienteSelect.dispatchEvent(new Event('change'));
          }

          const btnCobrar = document.getElementById('btnGenerarPedido') as HTMLButtonElement | null;
          if (btnCobrar) {
            btnCobrar.innerHTML = 'Actualizar Factura';
            btnCobrar.classList.remove('from-emerald-500', 'to-green-600', 'hover:from-emerald-600', 'hover:to-green-700', 'border-green-700');
            btnCobrar.classList.add('from-blue-500', 'to-blue-600', 'hover:from-blue-600', 'hover:to-blue-700', 'border-blue-700');
          }

          const btnCancelarEdicion = document.getElementById('btnCancelarEdicion');
          if (btnCancelarEdicion) {
            btnCancelarEdicion.addEventListener('click', () => {
              localStorage.removeItem('facturaEnEdicion');
              window.location.reload();
            });
          }
        } catch (error) {
          console.error('No se pudo cargar factura en edición:', error);
          localStorage.removeItem('facturaEnEdicion');
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', cargarFacturaEnEdicion);
      } else {
        cargarFacturaEnEdicion();
      }

      const renderizarPendientes = () => {
        listaPendientes.innerHTML = '';
        if (pedidosGuardados.length === 0) {
          listaPendientes.innerHTML = '<p class="text-center text-gray-500 text-sm mt-4">No hay órdenes pendientes.</p>';
          return;
        }

        pedidosGuardados.forEach(pedido => {
          const div = document.createElement('div');
          div.className = 'bg-white p-4 rounded-xl border border-gray-200 shadow-sm flex justify-between items-center hover:border-orange-400 cursor-pointer transition-colors';
          div.innerHTML = `
            <div>
              <h4 class="font-black text-gray-800 uppercase text-sm">${pedido.cliente}</h4>
              <p class="text-xs text-gray-500 font-bold">Guardado a las ${pedido.hora} • ${pedido.items.length} repuestos</p>
            </div>
            <button class="bg-orange-100 text-orange-700 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-orange-200">
              Continuar ➡️
            </button>
          `;

          div.addEventListener('click', async () => {
            if (carrito.length > 0) {
              const confirmado = await confirmarAccion('¿Reemplazar carrito?', 'Se reemplazará el carrito actual con esta orden pendiente.');
              if (!confirmado) return;
            }

            carrito.splice(0, carrito.length, ...JSON.parse(JSON.stringify(pedido.items)));
            const clienteSelect = document.getElementById('selectCliente') as HTMLSelectElement;
            if (clienteSelect) clienteSelect.value = pedido.cliente;

            pedidosGuardados = pedidosGuardados.filter(p => p.id !== pedido.id);
            actualizarBadgePendientes();
            renderCarrito();
            modalPendientes.classList.add('hidden');
            mostrarToast('Orden pendiente restaurada.', 'success');
          });

          listaPendientes.appendChild(div);
        });
      };

      // ── Abrir / cerrar checkout ────────────────────────────────────────────
      document.getElementById('btnGenerarPedido')?.addEventListener('click', () => {
        if (carrito.length === 0) {
          mostrarToast('El carrito está vacío.', 'error');
          return;
        }

        const totalBruto = carrito.reduce(
          (sum, item) => sum + (item.precio * item.cantidad - (item.descuentoTotal || 0)),
          0
        );
        setTotalBruto(totalBruto);
        resetCheckoutUI();
        inputMontoRecibido.value = totalBruto.toLocaleString('es-CO');
        actualizarCheckout();

        checkoutModal.classList.remove('hidden');
        setTimeout(() => {
          checkoutContainer.classList.remove('scale-95', 'opacity-0');
          checkoutContainer.classList.add('scale-100', 'opacity-100');
        }, 10);
      });

      document.getElementById('closeCheckout')?.addEventListener('click', () => {
        checkoutContainer.classList.remove('scale-100', 'opacity-100');
        checkoutContainer.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          checkoutModal.classList.add('hidden');
          resetCheckoutUI();
        }, 300);
      });

      // ── Confirmar pago ─────────────────────────────────────────────────────
      document.getElementById('btnConfirmarPago')?.addEventListener('click', async () => {
        if (carrito.length === 0) {
          mostrarToast('No hay productos para guardar.', 'error');
          return;
        }

        const btnConfirmar = document.getElementById('btnConfirmarPago') as HTMLButtonElement | null;
        const textoOriginalBtn = btnConfirmar?.innerHTML || '';

        if (btnConfirmar) {
          btnConfirmar.disabled = true;
          btnConfirmar.innerHTML = `
            <svg class="animate-spin h-5 w-5 text-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Guardando venta...
          `;
        }

        try {
          const { clienteSelect, cliente, telefono } = obtenerClienteActual();
          const ahora = new Date();
          const recibidoFinal = getRecibidoFinal();
          const fechaPagoInput = document.getElementById('inputFechaPago') as HTMLInputElement | null;
          const fechaVencimiento = fechaPagoInput?.value?.trim() ? fechaPagoInput.value : null;
          const facturaGuardada = localStorage.getItem('facturaEnEdicion');

          const estadoDB =
            tipoVenta === 'cotizacion'
              ? 'cotizacion'
              : tipoVenta === 'credito' || tipoVenta === 'abono'
              ? 'pendiente'
              : 'completada';

          const snapshotItems = JSON.parse(JSON.stringify(carrito));
          const payloadVenta = {
            cliente_nombre: cliente,
            cliente_telefono: telefono,
            subtotal: totalBrutoVenta,
            descuento_global: limpiarMoneda(globalDescVal.value),
            total_neto: totalNetoVenta,
            monto_recibido: recibidoFinal,
            tipo_venta: tipoVenta,
            metodo_pago: metodoPago,
            estado: estadoDB,
            fecha_vencimiento: fechaVencimiento,
            snapshot_carrito: carrito,
          };

          let ventaData: { id: string; fecha: string } | null = null;

          if (facturaGuardada) {
            // Si venimos de Historial, actualizamos la misma venta/cotización.
            const facturaAntigua = JSON.parse(facturaGuardada);
            const { data, error } = await supabase
              .from('ventas')
              .update(payloadVenta)
              .eq('id', facturaAntigua.id)
              .select('id, fecha')
              .single();

            if (error || !data) {
              throw new Error(error?.message || 'No se pudo actualizar la venta en edición.');
            }

            ventaData = data as { id: string; fecha: string };
          } else {
            // Flujo normal: insert de una venta nueva.
            const { data, error } = await supabase
              .from('ventas')
              .insert([payloadVenta])
              .select('id, fecha')
              .single();

            if (error || !data) {
              throw new Error(error?.message || 'No se pudo guardar la venta.');
            }

            ventaData = data as { id: string; fecha: string };
          }

          if (!ventaData) {
            throw new Error('No se obtuvo respuesta de la venta.');
          }

          const ventaId = ventaData.id;
          const numeroComprobante = obtenerNumeroComprobanteDesdeVentaId(ventaId);

          if (facturaGuardada) {
            const { error: borrarDetallesError } = await supabase
              .from('detalle_ventas')
              .delete()
              .eq('venta_id', ventaId);

            if (borrarDetallesError) {
              throw borrarDetallesError;
            }
          }

          // PASO 2: Preparar e insertar en 'detalle_ventas'
          const detallesParaInsertar = carrito.map(item => {
            const descTotal = item.descuentoTotal || 0;
            const subTotalCalculado = (item.precio * item.cantidad) - descTotal;

            return {
              venta_id: ventaId,
              referencia_id: item.id,
              cantidad: item.cantidad,
              precio_unitario: item.precio,
              subtotal: subTotalCalculado,
              modelo_snapshot: item.modelo,
              familia_snapshot: item.familia,
              descuento_linea: descTotal,
              subtotal_linea: subTotalCalculado,
            };
          });

          const { error: detallesError } = await supabase
            .from('detalle_ventas')
            .insert(detallesParaInsertar);

          if (detallesError) throw detallesError;

          const fechaVenta = ventaData.fecha ? new Date(ventaData.fecha) : ahora;
          const fechaFormateada =
            fechaVenta.toLocaleDateString('es-CO', { day: '2-digit', month: 'short' }) + ', ' +
            fechaVenta.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true });

          ultimaVenta = {
            cliente,
            telefono,
            fecha: fechaFormateada,
            numeroComprobante,
            items: snapshotItems,
            subtotal: totalBrutoVenta,
            descuentoGlobal: limpiarMoneda(globalDescVal.value),
            totalNeto: totalNetoVenta,
            recibido: recibidoFinal,
            tipoVenta,
            metodoPago,
          };

          successClienteName.innerText = cliente.toUpperCase();
          successFecha.innerText = fechaFormateada;
          successTotal.innerText = '$' + Math.round(totalNetoVenta).toLocaleString('es-CO');

          vaciarCarrito();
          if (clienteSelect) clienteSelect.value = 'Cliente Mostrador';
          renderCarrito();

          checkoutContainer.classList.remove('scale-100', 'opacity-100');
          checkoutContainer.classList.add('scale-95', 'opacity-0');
          setTimeout(() => checkoutModal.classList.add('hidden'), 150);

          setTimeout(() => {
            successModal.classList.remove('hidden');
            void successModal.offsetWidth;
            successModal.classList.remove('opacity-0');
            successContainer.classList.remove('scale-95');
            successContainer.classList.add('scale-100');
          }, 200);

          mostrarToast('Venta guardada correctamente.', 'success');

          // Salir de modo edición después de confirmar la venta
          localStorage.removeItem('facturaEnEdicion');

          const bannerEdicion = document.getElementById('bannerEdicion');
          if (bannerEdicion) {
            bannerEdicion.classList.add('hidden');
          }

          const btnCobrar = document.getElementById('btnGenerarPedido') as HTMLButtonElement | null;
          if (btnCobrar) {
            btnCobrar.innerHTML = 'Procesar Pedido';
            btnCobrar.classList.remove('from-blue-500', 'to-blue-600', 'hover:from-blue-600', 'hover:to-blue-700', 'border-blue-700');
            btnCobrar.classList.add('from-emerald-500', 'to-green-600', 'hover:from-emerald-600', 'hover:to-green-700', 'border-green-700');
          }
        } catch (error: any) {
          console.error('Error guardando venta en Supabase:', error);
          mostrarToast(error?.message || 'No se pudo guardar la venta.', 'error');
        } finally {
          if (btnConfirmar) {
            btnConfirmar.disabled = false;
            btnConfirmar.innerHTML = textoOriginalBtn;
          }
        }
      });

      // ── Botones de acciones PDF con estado de carga ────────────────────────
      const ejecutarConCarga = async (
        btn: HTMLButtonElement,
        venta: VentaSnapshot | null,
        accion: 'descargar' | 'imprimir'
      ) => {
        if (!venta) return;

        const textoOriginal = btn.innerHTML;
        btn.innerHTML = `
          <svg class="animate-spin h-5 w-5 text-current" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Procesando...
        `;
        btn.disabled = true;
        btn.classList.add('opacity-75', 'cursor-not-allowed');

        try {
          await generarFacturaPDF(venta, accion);
        } finally {
          btn.innerHTML = textoOriginal;
          btn.disabled = false;
          btn.classList.remove('opacity-75', 'cursor-not-allowed');
        }
      };

      // -----------------------------------------------------
      // LÓGICA DE COTIZAR (Conectado a Supabase)
      // -----------------------------------------------------
      document.getElementById('btnCotizar')?.addEventListener('click', async () => {
        if (carrito.length === 0) {
          mostrarToast("El carrito está vacío. Agrega repuestos para generar una cotización.", "error");
          return;
        }

        const btnCotizar = document.getElementById('btnCotizar') as HTMLButtonElement;
        const textoOriginal = btnCotizar.innerHTML;
        
        // Animación de carga
        btnCotizar.innerHTML = `<svg class="animate-spin h-5 w-5 text-current mr-2 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Creando...`;
        btnCotizar.disabled = true;

        try {
          const clienteSelect = document.getElementById('selectCliente') as HTMLSelectElement;
          const cliente = clienteSelect ? clienteSelect.value : 'Cliente Mostrador';
          const telefono = clienteSelect && clienteSelect.selectedIndex > -1 
            ? clienteSelect.options[clienteSelect.selectedIndex].getAttribute('data-telefono') || 'N/A' 
            : 'N/A';

          const subtotalCotizacion = carrito.reduce((sum, item) => sum + ((item.precio * item.cantidad) - (item.descuentoTotal || 0)), 0);

          // PASO 1: Guardar la Cotización en Supabase ('ventas')
          const { data: cotizacionData, error: cotizacionError } = await supabase
            .from('ventas')
            .insert([{
              cliente_nombre: cliente,
              cliente_telefono: telefono,
              subtotal: subtotalCotizacion,
              descuento_global: 0,
              total_neto: subtotalCotizacion, 
              monto_recibido: 0,
              tipo_venta: 'cotizacion',
              metodo_pago: 'N/A',
              estado: 'cotizacion',
              snapshot_carrito: carrito 
            }])
            .select('id, fecha')
            .single();

          if (cotizacionError) throw cotizacionError;

          const ventaId = cotizacionData.id;

          // PASO 2: Guardar los repuestos en 'detalle_ventas'
          const detallesParaInsertar = carrito.map(item => {
            const descTotal = item.descuentoTotal || 0;
            const subTotalCalculado = (item.precio * item.cantidad) - descTotal;

            return {
              venta_id: ventaId,
              referencia_id: item.id, 
              cantidad: item.cantidad,
              precio_unitario: item.precio,
              subtotal: subTotalCalculado,
              modelo_snapshot: item.modelo,
              familia_snapshot: item.familia,
              descuento_linea: descTotal,
              subtotal_linea: subTotalCalculado
            };
          });

          const { error: detallesError } = await supabase
            .from('detalle_ventas')
            .insert(detallesParaInsertar);

          if (detallesError) throw detallesError;

          // Preparamos la variable global para los botones PDF del modal
          ultimaCotizacion = {
            cliente: cliente,
            telefono: telefono,
            fecha: new Date(cotizacionData.fecha).toLocaleDateString('es-CO') + ' (Cotización)',
            numeroComprobante: obtenerNumeroComprobanteDesdeVentaId(cotizacionData.id),
            items: JSON.parse(JSON.stringify(carrito)),
            subtotal: subtotalCotizacion,
            descuentoGlobal: 0,
            totalNeto: subtotalCotizacion,
            recibido: 0,
            tipoVenta: 'cotizacion',
            metodoPago: 'N/A'
          };

          // Configurar Modal para Cotización Exitosa
          actionIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`;
          actionIcon.className = 'w-24 h-24 bg-blue-100 rounded-full flex items-center justify-center border-4 border-blue-200 text-5xl';
          actionTitle.innerText = 'Cotización Exitosa';
          actionTitle.className = 'text-2xl font-black text-blue-700 tracking-tighter uppercase';
          actionSubtitle.innerText = `Total cotizado: ${formatoPesos(subtotalCotizacion)}`;
          actionPdfButtons.classList.remove('hidden');

          // Limpiar vista y mostrar modal
          vaciarCarrito();
          actionSuccessModal.classList.remove('hidden');
          mostrarToast("Cotización guardada correctamente.", "success");

        } catch (error: any) {
          console.error("Error al cotizar:", error);
          mostrarToast("Hubo un error al guardar la cotización.", "error");
        } finally {
          btnCotizar.innerHTML = textoOriginal;
          btnCotizar.disabled = false;
        }
      });

      if (btnActionDescargar) {
        btnActionDescargar.addEventListener('click', () => {
          void ejecutarConCarga(btnActionDescargar, ultimaCotizacion, 'descargar');
        });
      }

      if (btnActionImprimir) {
        btnActionImprimir.addEventListener('click', () => {
          void ejecutarConCarga(btnActionImprimir, ultimaCotizacion, 'imprimir');
        });
      }

      // ── Lógica de guardar pedido ───────────────────────────────────────────
      if (btnGuardar) {
        btnGuardar.addEventListener('click', () => {
          if (carrito.length === 0) {
            mostrarToast('No hay repuestos para guardar.', 'error');
            return;
          }

          const { cliente, telefono } = obtenerClienteActual();

          pedidosGuardados.push({
            id: Date.now(),
            cliente,
            telefono,
            hora: new Date().toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit' }),
            items: JSON.parse(JSON.stringify(carrito)),
          });

          actualizarBadgePendientes();

          actionIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>`;
          actionIcon.className = 'w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center border-4 border-gray-300 text-5xl';
          actionTitle.innerText = 'Orden Guardada';
          actionTitle.className = 'text-2xl font-black text-gray-800 tracking-tighter uppercase';
          actionSubtitle.innerText = 'Puedes recuperarla desde el botón "Pendientes".';
          actionPdfButtons.classList.add('hidden');

          limpiarVistaVenta();
          actionSuccessModal.classList.remove('hidden');
          mostrarToast('Orden guardada en pendientes.', 'success');
        });
      }

      // ── Botones del modal de éxito ─────────────────────────────────────────
      if (btnImprimirReciboSuccess) {
        btnImprimirReciboSuccess.addEventListener('click', () => {
          void ejecutarConCarga(btnImprimirReciboSuccess, ultimaVenta, 'imprimir');
        });
      }

      btnNuevaVenta?.addEventListener('click', () => {
        successModal.classList.add('opacity-0');
        successContainer.classList.remove('scale-100');
        successContainer.classList.add('scale-95');
        setTimeout(() => successModal.classList.add('hidden'), 300);
      });

      if (btnActionNuevaVenta) {
        btnActionNuevaVenta.addEventListener('click', () => {
          actionSuccessModal.classList.add('hidden');
        });
      }

      // ── Descarga de PDF ────────────────────────────────────────────────────
      if (btnDescargarPDF) {
        btnDescargarPDF.addEventListener('click', () => {
          void ejecutarConCarga(btnDescargarPDF, ultimaVenta, 'descargar');
        });
      }

      // ── Botón imprimir de la vista previa ─────────────────────────────────
      if (btnPrintInvoice) {
        btnPrintInvoice.addEventListener('click', () => {
          void ejecutarConCarga(btnPrintInvoice, ultimaVenta, 'imprimir');
        });
      }

      // ── Pendientes ─────────────────────────────────────────────────────────
      if (btnVerPendientes) {
        btnVerPendientes.addEventListener('click', () => {
          renderizarPendientes();
          modalPendientes.classList.remove('hidden');
        });
      }

      if (closePendientes) {
        closePendientes.addEventListener('click', () => {
          modalPendientes.classList.add('hidden');
        });
      }

      // Deslizar al carrito cuando tocan el botón flotante en el celular
      const btnResumenMovil = document.getElementById('btnResumenMovil');
      if (btnResumenMovil) {
        btnResumenMovil.addEventListener('click', () => {
          document.getElementById('seccionCarrito')?.scrollIntoView({ behavior: 'smooth' });
        });
      }

      // ── Arranque inicial ───────────────────────────────────────────────────
      actualizarBadgePendientes();
      actualizarCheckout();

      // Lógica modularizada en src/pos/ventas/:
      // carrito.ts · checkout.ts · factura.ts · pdf.ts · filtros.ts · clientes.ts · utils.ts · types.ts

